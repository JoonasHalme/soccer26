# soccer26 environment template — copy to `.env` and fill in. `.env` is gitignored
# and must NEVER be committed or shipped in the build (the key is never written into
# any artifact; see model/fetch_odds.py).

# The Odds API key (https://the-odds-api.com). Free tier ≈ 500 requests/month.
# Used only by model/fetch_odds.py / model/capture_closing.py.
ODDS_API_KEY=your_key_here

# Public site URL — drives absolute sitemap / RSS / OG / canonical URLs at build.
# e.g. SITE_URL=https://yourdomain.com   (defaults to a placeholder if unset)
SITE_URL=
