---
import type { Squad } from "../lib/data";
interface Props { squad: Squad }
const { squad } = Astro.props;

const GROUPS = [
  { key: "GK", label: "Goalkeepers" },
  { key: "DF", label: "Defenders" },
  { key: "MF", label: "Midfielders" },
  { key: "FW", label: "Forwards" },
];
const known = new Set(GROUPS.map((g) => g.key));
const byPos = (k: string) => squad.players.filter((p) => p.pos === k);
const other = squad.players.filter((p) => !known.has(p.pos));
const groups = [
  ...GROUPS.filter((g) => byPos(g.key).length > 0),
  ...(other.length ? [{ key: "_other", label: "Other" }] : []),
];
const playersOf = (k: string) => (k === "_other" ? other : byPos(k));
---
<div class="squad">
  {(squad.coach || squad.players.length > 0) && (
    <p class="sq-meta">
      {squad.coach && <>Coach <b>{squad.coach}</b> · </>}
      {squad.players.length} players
    </p>
  )}
  <div class="sq-groups">
    {groups.map(({ key, label }) => (
      <div class="sq-group">
        <div class="sq-h"><span>{label}</span><span class="sq-n">{playersOf(key).length}</span></div>
        <ul class="sq-list">
          {playersOf(key).map((p) => (
            <li class="sq-row">
              <span class="sq-no">{p.no ?? "–"}</span>
              <span class="sq-name">
                {p.name}
                {p.club && <span class="sq-club">{p.club}</span>}
              </span>
              {p.caps != null && (
                <span class="sq-caps" title={`${p.caps} caps${p.goals != null ? `, ${p.goals} goals` : ""}`}>
                  {p.caps}<span class="sq-caps-l">cap{p.caps === 1 ? "" : "s"}</span>
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>

<style>
  .sq-meta { margin: 0 0 1rem; font-size: 0.9rem; color: var(--muted); }
  .sq-meta b { color: var(--fg); font-weight: 600; }
  .sq-groups {
    display: grid; gap: 1rem 1.4rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  .sq-group {
    border: 1px solid var(--border-soft); border-radius: var(--radius-sm);
    background: var(--surface); padding: 0.7rem 0.85rem;
  }
  .sq-h {
    display: flex; align-items: center; justify-content: space-between;
    font-family: var(--font-display); font-weight: 700; font-size: 0.78rem;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted-2);
    margin-bottom: 0.5rem;
  }
  .sq-n {
    font-family: var(--font-mono); font-size: 0.72rem; color: var(--muted-2);
    background: var(--surface-2); border-radius: var(--radius-sm); padding: 0.02rem 0.4rem;
  }
  .sq-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .sq-row {
    display: flex; align-items: baseline; gap: 0.6rem;
    padding: 0.35rem 0.1rem; border-top: 1px solid var(--border-soft);
  }
  .sq-row:first-child { border-top: none; }
  .sq-no {
    flex: 0 0 1.6rem; text-align: right;
    font-family: var(--font-mono); font-variant-numeric: tabular-nums;
    font-weight: 600; color: var(--accent); font-size: 0.9rem;
  }
  .sq-name { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.05rem; color: var(--fg); font-weight: 500; }
  .sq-club { font-size: 0.74rem; color: var(--muted-2); font-weight: 400; }
  .sq-caps {
    flex: 0 0 auto; text-align: right; white-space: nowrap;
    font-family: var(--font-mono); font-variant-numeric: tabular-nums;
    font-size: 0.82rem; color: var(--muted);
  }
  .sq-caps-l { font-family: var(--font-sans, inherit); font-size: 0.62rem; color: var(--muted-2); margin-left: 0.25rem; text-transform: uppercase; letter-spacing: 0.03em; }
</style>
