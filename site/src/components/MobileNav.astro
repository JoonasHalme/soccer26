---
// Fixed bottom tab bar for phones (≤720px) — native mobile nav pattern for the 5
// primary routes; the top scroller keeps the secondary ones. Safe-area aware.
const path = Astro.url.pathname;
const active = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));

const items = [
  { href: "/", label: "Today", svg: '<path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/>' },
  { href: "/edges", label: "Edges", svg: '<path d="M3 17l6-6 4 4 8-8"/><path d="M16 7h5v5"/>' },
  { href: "/matches", label: "Matches", svg: '<rect x="3" y="4.5" width="18" height="16" rx="1.5"/><path d="M3 9h18M8 2.5v4M16 2.5v4"/>' },
  { href: "/bracket", label: "Bracket", svg: '<path d="M4 5h5v5M4 19h5v-5M9 7.5h4v9h4M17 12h3"/>' },
  { href: "/bets", label: "Record", svg: '<path d="M5 20V11M12 20V4M19 20v-6M3 20h18"/>' },
];
---
<nav class="mobilenav" aria-label="Primary (mobile)">
  {items.map((it) => (
    <a href={it.href} class={`mn-item ${active(it.href) ? "is-active" : ""}`}
       aria-current={active(it.href) ? "page" : undefined}>
      <svg viewBox="0 0 24 24" aria-hidden="true" set:html={it.svg}></svg>
      <span>{it.label}</span>
    </a>
  ))}
</nav>

<style>
  .mobilenav {
    display: none;
    position: fixed; inset: auto 0 0 0; z-index: 60;
    grid-template-columns: repeat(5, 1fr);
    background: color-mix(in srgb, var(--surface-2) 88%, transparent);
    border-top: 1px solid var(--border);
    padding-bottom: env(safe-area-inset-bottom);
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
  }
  @media (max-width: 720px) { .mobilenav { display: grid; } }

  .mn-item {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    padding: 0.5rem 0 0.45rem;
    color: var(--muted-2); text-decoration: none;
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .mn-item svg {
    width: 22px; height: 22px;
    stroke: currentColor; fill: none;
    stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round;
  }
  .mn-item:active { background: var(--elev); }
  .mn-item.is-active { color: var(--accent); }
</style>
