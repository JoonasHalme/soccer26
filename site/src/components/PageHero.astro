---
// Shared page hero — the single hero treatment for the whole site (the per-page
// glow-gradient panels were the #1 "AI landing page" tell). Flat surface + 1px
// border + a catch-light; no radial wash. Pass the subtitle + any chips as
// default-slot content. `size="display"` gives the homepage a larger headline.
interface Props {
  eyebrow?: string;
  title: string;
  tint?: "green" | "cyan" | "gold" | "violet"; // accepted for back-compat; no longer a glow
  size?: "default" | "display";
}
const { eyebrow, title, size = "default" } = Astro.props;
---
<section class={`pagehero size-${size}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1 class="ph-title">{title}</h1>
  <slot />
</section>

<style>
  .pagehero {
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    /* a barely-there vertical surface lift — NOT a coloured glow */
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    padding: var(--s-6) var(--s-5);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }
  .ph-title { margin: var(--s-1) 0 0; }
  .size-display .ph-title {
    font-size: clamp(2rem, 4.6vw, var(--t-display));
    line-height: var(--lh-tight);
    letter-spacing: -0.03em;
  }
  @media (max-width: 720px) { .pagehero { padding: var(--s-5) var(--s-4); } }
</style>
