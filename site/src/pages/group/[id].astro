---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import GroupCard from "../../components/GroupCard.astro";
import MatchCard from "../../components/MatchCard.astro";
import NewsItem from "../../components/NewsItem.astro";
import TeamFlag from "../../components/TeamFlag.astro";
import LocalTime from "../../components/LocalTime.astro";
import {
  loadFixtures, loadPredictions, loadNews,
  computeStandings, allEdges, selectionLabel, teamSlug, pct1,
} from "../../lib/data";

// One static page per group, enumerated from the fixtures groups.
export function getStaticPaths() {
  const { groups } = loadFixtures();
  return Object.keys(groups).map((letter) => ({
    params: { id: letter.toLowerCase() },
    props: { letter },
  }));
}

const { letter } = Astro.props;

const { matches, groups } = loadFixtures();
const { predictions } = loadPredictions();
const news = loadNews();

const teams = groups[letter] ?? [];
const standings = computeStandings(matches, groups);
const groupRows = standings[letter] ?? [];
const started = groupRows.reduce((s, r) => s + r.played, 0) > 0;

const fixtures = matches
  .filter((m) => m.stage === "GROUP" && m.group === letter)
  .sort((a, b) => (a.kickoff ?? "").localeCompare(b.kickoff ?? ""));
const predById = new Map(predictions.map((p) => [p.match_id, p]));
const analyzedIds = new Set((await getCollection("matches")).map((a) => a.data.match_id));

const teamSet = new Set(teams);
const edges = allEdges(predictions, matches)
  .filter((e) => e.group === letter)
  .sort((a, b) => b.edge_pct - a.edge_pct);

const groupNews = news.items
  .filter((n) => n.teams.some((t) => teamSet.has(t)))
  .slice(0, 8);

const title = `Group ${letter} — World Cup 2026 standings, fixtures & value edges | Soccer 26`;
const description = `FIFA World Cup 2026 Group ${letter}: ${teams.join(", ")}. Live standings, full fixtures with model win probabilities, value edges vs the de-vigged market, and team news.`;

---
<Base title={title} description={description} ogImage={`/og/group/${letter.toLowerCase()}.png`}>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/groups">Groups</a> <span aria-hidden="true">/</span>
    <span aria-current="page">Group {letter}</span>
  </nav>

  <section class="gr-hero">
    <span class="gr-letter">{letter}</span>
    <div class="gr-hero-body">
      <p class="eyebrow">FIFA World Cup 2026 · Group stage</p>
      <h1>Group {letter}</h1>
      <div class="gr-teams">
        {teams.map((t) => (
          <a class="gr-team" href={`/team/${teamSlug(t)}`}>
            <TeamFlag team={t} size={18} /><span>{t}</span>
          </a>
        ))}
      </div>
    </div>
    <div class={`gr-stat ${started ? "accent" : ""}`}>
      <span class="gr-stat-n">{groupRows.reduce((s, r) => s + r.played, 0)}</span>
      <span class="gr-stat-l">played</span>
    </div>
  </section>

  <section class="gr-section">
    <div class="section-head"><h2>Standings</h2><span class="count">{started ? "live table" : "not started"}</span><span class="rule"></span></div>
    <GroupCard letter={letter} rows={groupRows} full />
  </section>

  <section class="gr-section">
    <div class="section-head"><h2>Fixtures</h2><span class="count">{fixtures.length} match{fixtures.length === 1 ? "" : "es"}</span><span class="rule"></span></div>
    {fixtures.length === 0 ? (
      <div class="panel"><p class="subtle" style="margin:0">No group fixtures found.</p></div>
    ) : (
      <div class="cards-grid">
        {fixtures.map((m) => (
          <MatchCard match={m} pred={predById.get(m.id)} analyzed={analyzedIds.has(m.id)} />
        ))}
      </div>
    )}
  </section>

  {edges.length > 0 && (
    <section class="gr-section">
      <div class="section-head"><h2>Value edges</h2><span class="count">model vs market</span><span class="rule"></span><a href="/edges" class="see-all">All edges →</a></div>
      <div class="table-wrap">
        <table class="gr-edges table--cards">
          <thead>
            <tr><th>Match</th><th>Selection</th><th class="num">Edge</th><th>Best price</th><th>Kickoff</th></tr>
          </thead>
          <tbody>
            {edges.map((e) => (
              <tr>
                <td><a href={`/matches/${e.match_id}`}>{e.home} vs {e.away}</a></td>
                <td data-label="Selection">{selectionLabel(e.selection, e.home, e.away)}</td>
                <td class="num" data-label="Edge"><span class="badge badge-edge">+{pct1(e.edge_pct)}%</span></td>
                <td data-label="Best price">{e.best_odds ? <span class="best"><b>{e.best_odds.toFixed(2)}</b> <span class="bk">{e.best_book}</span></span> : <span class="subtle">{e.odds_decimal?.toFixed(2) ?? "—"}</span>}</td>
                <td class="meta" data-label="Kickoff"><LocalTime iso={e.kickoff} fmt="datetime" /></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  {groupNews.length > 0 && (
    <section class="gr-section">
      <div class="section-head"><h2>Group {letter} team news</h2><span class="count">RSS</span><span class="rule"></span></div>
      <div class="news-grid">
        {groupNews.map((item) => <NewsItem item={item} highlightTeams={teams} />)}
      </div>
    </section>
  )}
</Base>

<style>
  .crumbs { font-size: 0.82rem; color: var(--muted-2); margin-bottom: 0.9rem; display: flex; gap: 0.45rem; flex-wrap: wrap; }
  .crumbs a { color: var(--muted); text-decoration: none; }
  .crumbs a:hover { color: var(--accent); text-decoration: underline; }

  .gr-hero {
    display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    padding: var(--s-5) var(--s-5);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }
  .gr-letter {
    display: grid; place-items: center;
    width: 3rem; height: 3rem; border-radius: 12px;
    font-family: var(--font-display); font-weight: 800; font-size: 1.6rem;
    color: var(--accent-ink);
    background: linear-gradient(140deg, var(--accent), var(--accent-2));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.25);
  }
  .gr-hero-body { flex: 1; min-width: 220px; }
  .gr-hero-body h1 { margin: 0.15rem 0 0.5rem; }
  .gr-teams { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .gr-team {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.25rem 0.6rem; border-radius: var(--radius-sm);
    border: 1px solid var(--border-strong); background: rgba(10,12,20,0.4);
    font-size: 0.82rem; font-weight: 600; color: var(--fg); text-decoration: none;
  }
  .gr-team:hover { border-color: var(--accent-line); color: var(--accent); text-decoration: none; }

  .gr-stat { display: flex; flex-direction: column; align-items: center; gap: 0.05rem; padding: 0 0.6rem; }
  .gr-stat-n { font-family: var(--font-mono); font-weight: 600; font-size: 1.55rem; color: var(--fg); font-variant-numeric: tabular-nums slashed-zero; line-height: 1; }
  .gr-stat.accent .gr-stat-n { color: var(--accent); }
  .gr-stat-l { font-size: 0.72rem; color: var(--muted-2); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }

  .gr-section { margin-top: 2.1rem; }
  .cards-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
  .news-grid { display: grid; gap: 0.7rem; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); }
  .see-all { font-size: 0.85rem; font-weight: 600; white-space: nowrap; }

  .table-wrap { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1px solid var(--border-soft); border-radius: var(--radius-sm); }
  .gr-edges { border-collapse: collapse; width: 100%; font-size: 0.9rem; }
  .gr-edges th, .gr-edges td { text-align: left; padding: 0.6rem 0.8rem; border-bottom: 1px solid var(--border-soft); white-space: nowrap; }
  .gr-edges thead th { color: var(--muted-2); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .gr-edges tbody tr:last-child td { border-bottom: none; }
  .gr-edges .num { text-align: right; }
  .gr-edges a { color: var(--link); text-decoration: none; }
  .gr-edges a:hover { text-decoration: underline; }
  .best b { font-variant-numeric: tabular-nums; }
  .bk { color: var(--muted-2); font-size: 0.78rem; }

  @media (max-width: 720px) {
    .gr-hero { padding: 1.2rem 1.1rem; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
