---
import Base from "../layouts/Base.astro";
import Tooltip from "../components/Tooltip.astro";
import { loadBets, loadFixtures, bankrollStats, clvStats, pnlSeries, selectionLabel, signed, signedPct, money } from "../lib/data";

const { bets, currency, starting_bankroll, unit_size } = loadBets();
const { matches } = loadFixtures();
const matchById = new Map(matches.map((m) => [m.id, m]));
// Resolve a bet's match_id to its "Home vs Away" label and the team names so
// the selection can be rendered in human terms too. Falls back to the raw id.
const teamsFor = (matchId: string) => {
  const m = matchById.get(matchId);
  return m ? { home: m.home, away: m.away, label: `${m.home} vs ${m.away}` }
           : { home: "", away: "", label: matchId };
};
const stats = bankrollStats(bets);
const clv = clvStats(bets);

// ---- Equity curve geometry (cumulative bankroll after each settled bet) ----
const series = pnlSeries(bets, starting_bankroll);
const VW = 720, VH = 180, PAD = 8;
// Anchor the line at the starting bankroll (point 0), then each settled bet.
const points = [{ n: 0, bankroll: starting_bankroll }, ...series];
const values = points.map((p) => p.bankroll);
const lo = Math.min(starting_bankroll, ...values);
const hi = Math.max(starting_bankroll, ...values);
const span = hi - lo || 1;
const xAt = (i: number) =>
  PAD + (points.length <= 1 ? 0 : (i / (points.length - 1)) * (VW - 2 * PAD));
const yAt = (v: number) => VH - PAD - ((v - lo) / span) * (VH - 2 * PAD);
const linePts = points.map((p, i) => `${xAt(i).toFixed(1)},${yAt(p.bankroll).toFixed(1)}`).join(" ");
const areaPts = `${xAt(0).toFixed(1)},${(VH - PAD).toFixed(1)} ${linePts} ${xAt(points.length - 1).toFixed(1)},${(VH - PAD).toFixed(1)}`;
const baselineY = yAt(starting_bankroll).toFixed(1);
const finalUp = series.length > 0 && series[series.length - 1].bankroll >= starting_bankroll;
const sorted = [...bets].sort((a, b) => b.placed_at.localeCompare(a.placed_at));
const resultClass = (r?: string | null) =>
  r === "WIN" ? "win" : r === "LOSS" ? "loss" : r ? "" : "open";
const bankroll = starting_bankroll + stats.pnl;

const fmtClv = (v?: number | null) =>
  typeof v === "number" ? signedPct(v, 1) : "—";
const clvClass = (v?: number | null) =>
  typeof v !== "number" ? "" : v > 0 ? "pos" : v < 0 ? "neg" : "";
const sourceRows = Object.entries(clv.bySource);
const marketRows = Object.entries(clv.byMarket);
---
<Base title="Bets — Soccer 26" ogImage="/og/track-record.png">
  <p class="eyebrow">Bankroll</p>
  <h1 style="margin-bottom:0.5rem;">Bet log</h1>
  <p class="subtle" style="margin-top:0;">
    Starting bankroll {starting_bankroll} {currency} · {unit_size} {currency} unit.
    Current bankroll <strong style="color:var(--fg)">{bankroll.toFixed(2)} {currency}</strong>.
  </p>

  <section class="grid cols-4" style="margin-top:1.25rem; margin-bottom: 1.75rem;" aria-label="Bet log summary">
    <div class="panel stat-card">
      <div class="stat-label">Profit / Loss</div>
      <div class={`stat-value ${stats.pnl >= 0 ? "pos" : "neg"}`}>{money(stats.pnl, currency)}</div>
      <div class="stat-sub">{stats.wins}W · {stats.losses}L</div>
    </div>
    <div class="panel stat-card tone-cyan">
      <div class="stat-label">ROI</div>
      <div class={`stat-value ${stats.roi >= 0 ? "pos" : "neg"}`}>{signedPct(stats.roi, 1)}</div>
      <div class="stat-sub">on staked capital</div>
    </div>
    <div class="panel stat-card tone-mag">
      <div class="stat-label">Settled</div>
      <div class="stat-value">{stats.count}</div>
      <div class="stat-sub">resolved bets</div>
    </div>
    <div class="panel stat-card tone-warn">
      <div class="stat-label">Total staked</div>
      <div class="stat-value">{stats.totalStake.toFixed(0)} {currency}</div>
      <div class="stat-sub">cumulative exposure</div>
    </div>
  </section>

  <p class="eyebrow" style="margin-top:0.5rem;">Closing-line value</p>
  <h2 style="margin:0.1rem 0 0.35rem;">Did you beat the close?</h2>
  <p class="subtle" style="margin-top:0;max-width:70ch;">
    CLV measures each bet against the <Tooltip term="de-vigged" def="Bookmaker odds carry a margin (the vig). De-vigging rescales a market's implied probabilities to sum to 1, giving the market's true fair price." /> <strong>closing</strong> line — the
    sharpest price the market makes. On a small World Cup sample it is a more honest
    skill signal than raw P/L (which is mostly variance). Beating the close doesn't
    guarantee profit, and missing it doesn't prove a bad bet — but consistently
    positive CLV is the strongest evidence the picks carry real edge.
  </p>

  <section class="grid cols-3" style="margin-top:0.9rem;margin-bottom:0.7rem;" aria-label="CLV scoreboard">
    <div class="panel stat-card tone-cyan">
      <div class="stat-label">CLV beat-rate <span class="lead-tag">lead metric</span></div>
      <div class={`stat-value ${clv.beatRate != null && clv.beatRate >= 50 ? "pos" : clv.beatRate != null ? "neg" : ""}`}>
        {clv.beatRate != null ? `${clv.beatRate.toFixed(0)}%` : "—"}
      </div>
      <div class="stat-sub">
        {clv.beatRateCI
          ? `95% CI ${clv.beatRateCI.low.toFixed(0)}–${clv.beatRateCI.high.toFixed(0)}% · ${clv.positive}/${clv.rated} beat the close`
          : `${clv.positive}/${clv.rated} beat the close`}
      </div>
    </div>
    <div class="panel stat-card">
      <div class="stat-label">Average CLV</div>
      <div class={`stat-value ${clvClass(clv.stakeWeightedClv ?? clv.avgClv)}`}>{fmtClv(clv.stakeWeightedClv ?? clv.avgClv)}</div>
      <div class="stat-sub">
        {clv.stakeWeightedClv != null ? "stake-weighted" : "mean vs close"}
        {clv.avgClvCI && ` · mean ${fmtClv(clv.avgClv)} (CI ${clv.avgClvCI.low.toFixed(1)}…${clv.avgClvCI.high.toFixed(1)}%)`}
      </div>
    </div>
    <div class="panel stat-card tone-mag">
      <div class="stat-label">CLV-rated</div>
      <div class="stat-value">{clv.rated}</div>
      <div class="stat-sub">scored against the close</div>
    </div>
  </section>
  <p class="subtle clv-note" style="margin:0 0 1.5rem; font-size:0.82rem;">
    We lead with the <b>beat-rate</b> (share of bets that beat the close) and its <b>binomial
    95% CI</b> — on a small sample it's the cleaner skill signal than the mean CLV, whose
    spread is dominated by a few longshots. Average CLV is shown stake-weighted for the same
    reason; its mean t-interval is the wide, fragile one.
  </p>

  <section class="panel" style="margin-bottom:1.6rem;">
    <div class="section-head">
      <h2>Bankroll equity curve</h2>
      <span class="count">cumulative P/L across settled bets</span>
      <span class="rule"></span>
    </div>
    {series.length === 0 ? (
      <p class="subtle" style="margin:0;">
        The equity curve plots your bankroll after each settled bet. It appears here
        once the first bet is graded — currently a flat line at the
        {` ${starting_bankroll} ${currency}`} starting bankroll.
      </p>
    ) : (
      <p class="subtle" style="margin:0 0 0.6rem;">
        {series.length} settled bet{series.length === 1 ? "" : "s"} ·
        {` ${starting_bankroll} ${currency}`} →
        <strong class={finalUp ? "pos" : "neg"}> {series[series.length - 1].bankroll.toFixed(2)} {currency}</strong>
      </p>
    )}
    <div class="sr-only">
      {series.length === 0 ? (
        <p>
          Bankroll equity curve. No settled bets yet, so the curve is a flat line
          at the {starting_bankroll} {currency} starting bankroll.
        </p>
      ) : (
        <>
          <p>
            Bankroll equity curve across {series.length} settled
            bet{series.length === 1 ? "" : "s"}. Starting bankroll
            {` ${starting_bankroll} ${currency}`}; current bankroll
            {` ${series[series.length - 1].bankroll.toFixed(2)} ${currency}`};
            net profit and loss
            {` ${signed(stats.pnl, 2)} ${currency}`}
            ({signedPct(stats.roi, 1)} ROI).
          </p>
          <table>
            <caption>Cumulative bankroll after each settled bet</caption>
            <thead>
              <tr>
                <th scope="col">Bet</th>
                <th scope="col">Date</th>
                <th scope="col">Result</th>
                <th scope="col">Cumulative P/L ({currency})</th>
                <th scope="col">Bankroll ({currency})</th>
              </tr>
            </thead>
            <tbody>
              {series.map((p) => (
                <tr>
                  <td>{p.n}</td>
                  <td>{p.date}</td>
                  <td>{p.result}</td>
                  <td>{p.pnl >= 0 ? "+" : ""}{p.pnl.toFixed(2)}</td>
                  <td>{p.bankroll.toFixed(2)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </>
      )}
    </div>
    <svg class="equity" viewBox={`0 0 ${VW} ${VH}`} preserveAspectRatio="none"
         aria-hidden="true">
      <line x1={PAD} y1={baselineY} x2={VW - PAD} y2={baselineY}
            class="equity-base" vector-effect="non-scaling-stroke" />
      {series.length > 0 && (
        <>
          <polygon points={areaPts} class={`equity-area ${finalUp ? "up" : "down"}`} />
          <polyline points={linePts} class={`equity-line ${finalUp ? "up" : "down"}`}
                    vector-effect="non-scaling-stroke" />
        </>
      )}
    </svg>
  </section>

  {(sourceRows.length > 0 || marketRows.length > 0) && (
    <section class="grid cols-2" style="margin-bottom:1.6rem;gap:1rem;">
      <div class="panel">
        <div class="section-head"><h2>P/L by source</h2><span class="count">model vs gut</span><span class="rule"></span></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Source</th><th class="num">Bets</th><th class="num">P/L</th><th class="num">ROI</th></tr></thead>
            <tbody>
              {sourceRows.map(([k, r]) => (
                <tr>
                  <td>{k}</td>
                  <td class="num">{r.bets}</td>
                  <td class={`num ${r.pnl >= 0 ? "pos" : "neg"}`}>{signed(r.pnl, 2)}</td>
                  <td class="num">{r.roi != null ? signedPct(r.roi, 1) : "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <div class="panel">
        <div class="section-head"><h2>P/L by market</h2><span class="count">where it pays</span><span class="rule"></span></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Market</th><th class="num">Bets</th><th class="num">P/L</th><th class="num">ROI</th></tr></thead>
            <tbody>
              {marketRows.map(([k, r]) => (
                <tr>
                  <td>{k}</td>
                  <td class="num">{r.bets}</td>
                  <td class={`num ${r.pnl >= 0 ? "pos" : "neg"}`}>{signed(r.pnl, 2)}</td>
                  <td class="num">{r.roi != null ? signedPct(r.roi, 1) : "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  {sorted.length === 0 ? (
    <div class="empty">
      <h2 style="margin:0 0 0.3rem;">No settled bets yet</h2>
      <p class="subtle" style="margin:0; max-width:52ch;">
        CLV and P/L populate automatically once bets are logged and results arrive.
        Append entries to <code>bets/bets.json</code>; then
        <code>fetch_results.py</code> → <code>settle.py</code> → <code>clv.py</code>
        grade them and score each against the de-vigged close.
      </p>
    </div>
  ) : (
    <div class="table-wrap">
      <table class="table--cards">
        <thead>
          <tr><th>Match</th><th>Placed</th><th>Market</th><th>Selection</th><th class="num">Odds</th><th class="num">Stake</th><th class="num">Edge</th><th class="num">CLV</th><th>Result</th><th class="num">P/L</th></tr>
        </thead>
        <tbody>
          {sorted.map((b) => {
            const t = teamsFor(b.match_id);
            return (
            <tr>
              <td><a href={`/matches/${b.match_id}`}>{t.label}</a></td>
              <td data-label="Placed" style="white-space:nowrap">{b.placed_at.slice(0, 10)}</td>
              <td data-label="Market">{b.market}</td>
              <td data-label="Selection">{selectionLabel(b.selection, t.home, t.away)}</td>
              <td class="num" data-label="Odds">{b.odds_decimal.toFixed(2)}</td>
              <td class="num" data-label="Stake">{b.stake.toFixed(2)}</td>
              <td class="num" data-label="Edge">{b.model_edge_pct != null ? `${(b.model_edge_pct * 100).toFixed(1)}%` : "—"}</td>
              <td class={`num ${clvClass(b.clv_pct)}`} data-label="CLV">{fmtClv(b.clv_pct)}</td>
              <td data-label="Result"><span class={`pill ${resultClass(b.result)}`}>{b.result ?? "OPEN"}</span></td>
              <td class={`num ${b.pnl != null && b.pnl >= 0 ? "pos" : "neg"}`} data-label="P/L">{b.pnl != null ? signed(b.pnl, 2) : "—"}</td>
            </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</Base>

<style>
  .lead-tag {
    font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
    color: var(--info); background: var(--info-soft); border: 1px solid var(--info-line);
    border-radius: var(--radius-sm); padding: 0.02rem 0.34rem; vertical-align: 1px; margin-left: 0.35rem;
  }
  .clv-note b { color: var(--fg); font-weight: 600; }
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  .empty {
    display: flex; flex-direction: column; align-items: center; text-align: center;
    gap: 0.4rem; padding: 3rem 1.5rem;
    border: 1px dashed var(--border-strong); border-radius: var(--radius-lg);
    background: var(--surface);
  }

  .equity { width: 100%; height: 180px; display: block; margin-top: 0.4rem; }
  .equity-base { stroke: var(--border-strong); stroke-width: 1; stroke-dasharray: 4 4; }
  .equity-line { fill: none; stroke-width: 2.5; }
  .equity-line.up { stroke: var(--accent); }
  .equity-line.down { stroke: var(--bad); }
  .equity-area { opacity: 0.16; }
  .equity-area.up { fill: var(--accent); }
  .equity-area.down { fill: var(--bad); }
</style>
