---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import TeamFlag from "../components/TeamFlag.astro";
import LocalTime from "../components/LocalTime.astro";
import { loadFixtures, flagCode } from "../lib/data";
import type { Match } from "../lib/data";

const { matches } = loadFixtures();

// ── Topology ───────────────────────────────────────────────────────────────
// The knockout draw is a perfect binary tree: every knockout slot is a code
// like "W74" (winner of match 74) or "1E"/"3A/B/C/D/F" (group slots, the R32
// leaves). We resolve `W<n>`/`L<n>` to the match with that `game_no`, walk the
// tree down from the Final, and lay every tie out at its true bracket position
// with SVG elbows linking each pair to the tie it feeds. It fills in with real
// teams + flags automatically as the group stage resolves the slot codes.
const STAGES: { key: Match["stage"]; label: string; count: number }[] = [
  { key: "R32", label: "Round of 32", count: 16 },
  { key: "R16", label: "Round of 16", count: 8 },
  { key: "QF", label: "Quarter-finals", count: 4 },
  { key: "SF", label: "Semi-finals", count: 2 },
  { key: "FINAL", label: "Final", count: 1 },
];

const byGameNo = new Map<number, Match>();
for (const m of matches) {
  const n = m.game_no ?? Number(m.id.replace(/\D/g, ""));
  if (Number.isFinite(n)) byGameNo.set(n, m);
}
const feeder = (slot?: string): Match | undefined => {
  const hit = slot?.match(/^[WL](\d+)$/);
  return hit ? byGameNo.get(Number(hit[1])) : undefined;
};

// Post-order DFS from the Final (home subtree before away) gives every round its
// ties in true top-to-bottom bracket order — so consecutive pairs (2j, 2j+1)
// feed receiver j, which the connector geometry relies on.
const order = new Map<string, number>();
let counter = 0;
const walk = (m?: Match) => {
  if (!m || order.has(m.id)) return;
  walk(feeder(m.home));
  walk(feeder(m.away));
  order.set(m.id, counter++);
};
const final = matches.find((m) => m.stage === "FINAL");
walk(final);

const orderedByStage = (stage: Match["stage"]) =>
  matches
    .filter((m) => m.stage === stage)
    .sort(
      (a, b) =>
        (order.get(a.id) ?? 1e9) - (order.get(b.id) ?? 1e9) ||
        (a.kickoff ?? "").localeCompare(b.kickoff ?? "") ||
        a.id.localeCompare(b.id),
    );

const rounds = STAGES.map((s) => ({ ...s, ties: orderedByStage(s.key) }));
const thirdPlace = orderedByStage("3RD")[0];

// ── Layout geometry (deterministic px so the SVG elbows align exactly) ───────
const COL_W = 208;
const GAP_W = 46;
const TIE_H = 62;
const PITCH = 78; // vertical pitch of the R32 column
const H = 16 * PITCH; // board height; every column shares it
const CHAMP_W = 168;

const tieY = (i: number, count: number) => ((i + 0.5) * H) / count;

// One SVG path per gap: each receiver j joins its two feeders (2j, 2j+1) with a
// horizontal stub → vertical riser → horizontal arm into the next column.
const half = GAP_W / 2;
const r2 = (n: number) => Math.round(n * 100) / 100;
const gapPath = (feederCount: number) => {
  const recv = feederCount / 2;
  let d = "";
  for (let j = 0; j < recv; j++) {
    const y0 = r2(tieY(2 * j, feederCount));
    const y1 = r2(tieY(2 * j + 1, feederCount));
    const yr = r2(tieY(j, recv));
    d += `M0 ${y0}H${half}M0 ${y1}H${half}M${half} ${y0}V${y1}M${half} ${yr}H${GAP_W}`;
  }
  return d;
};
const gapPaths = STAGES.slice(0, -1).map((s) => gapPath(s.count));
const totalW = STAGES.length * COL_W + (STAGES.length - 1) * GAP_W + GAP_W + CHAMP_W;

// ── Slot / status helpers (same empty-state-safe pattern as the standings) ───
const isTeam = (slot?: string) => !!slot && flagCode(slot) !== null;

const fmtKick = (k?: string) =>
  k
    ? new Date(k).toLocaleString("en-GB", {
        weekday: "short", day: "numeric", month: "short",
        hour: "2-digit", minute: "2-digit", hour12: false,
      })
    : "Date TBD";
const shortDate = (k?: string) =>
  k ? new Date(k).toLocaleDateString("en-GB", { day: "numeric", month: "short" }) : "TBD";

const totalTies = rounds.reduce((s, r) => s + r.ties.length, 0) + (thirdPlace ? 1 : 0);
const resolved = matches.filter(
  (m) =>
    ["R32", "R16", "QF", "SF", "3RD", "FINAL"].includes(m.stage) &&
    isTeam(m.home) && isTeam(m.away),
).length;

// Champion = winner of the Final, once it's played; otherwise the trophy is open.
const champion = (() => {
  if (!final?.score || final.score.home == null || final.score.away == null) return null;
  if (final.score.home === final.score.away) return null;
  return final.score.home > final.score.away ? final.home : final.away;
})();
---
<Base title="Knockout bracket — Soccer 26">
  <PageHero eyebrow="FIFA World Cup 2026 · Knockout stage" title="Knockout bracket" tint="violet">
    <p class="subtle" style="max-width: 64ch; margin: 0.4rem 0 0;">
      The full path from the Round of 32 to the Final, drawn as a true bracket —
      each tie is wired to the one it feeds. Slots show a real team with its flag
      once the group stage resolves them, otherwise the placeholder code (e.g.
      <code>W74</code> = winner of match 74, <code>3A/B/C/D/F</code> = a qualifying
      third-placed team). It fills in automatically as results land.
    </p>
    <div class="hero-chips" style="margin-top: 1rem;">
      <span class="hero-chip"><b>{totalTies}</b> ties</span>
      <span class={`hero-chip ${resolved > 0 ? "accent" : ""}`}>
        <b>{resolved}</b> with both teams set
      </span>
    </div>
  </PageHero>

  {resolved === 0 && (
    <div class="panel not-started" role="status" style="margin-top:1.2rem;">
      <span class="ns-dot" aria-hidden="true"></span>
      <span>
        <b>Knockout teams not yet decided.</b> Every tie shows placeholder slots until
        the group stage finishes — the bracket comes alive automatically as teams
        qualify in <code>fixtures.json</code>.
      </span>
    </div>
  )}

  <div class="bk-scroll">
    <div class="bk-stage" style={`min-width:${totalW}px;`}>
      <!-- Round headers (kept in lock-step with the board's column widths). -->
      <div class="bk-heads" aria-hidden="true">
        {rounds.map((r, ri) => (
          <>
            <div class="bk-head" data-stage={r.key} style={`width:${COL_W}px`}>
              <span class="bk-head-label">{r.label}</span>
              <span class="bk-head-n">{r.ties.length}</span>
            </div>
            {ri < rounds.length - 1 && <div class="bk-head-gap" style={`width:${GAP_W}px`}></div>}
          </>
        ))}
        <div class="bk-head-gap" style={`width:${GAP_W}px`}></div>
        <div class="bk-head" data-stage="CHAMP" style={`width:${CHAMP_W}px`}>
          <span class="bk-head-label">Champion</span>
        </div>
      </div>

      <div class="bk-board" style={`--bk-h:${H}px;`}>
        {rounds.map((r, ri) => (
          <>
            <div class="bk-round" data-stage={r.key} style={`width:${COL_W}px;height:${H}px;`}>
              {r.ties.map((m, i) => (
                <a
                  class="bk-tie"
                  data-stage={r.key}
                  style={`top:${r2(tieY(i, r.count))}px;`}
                  href={`/matches/${m.id}`}
                  aria-label={`${r.label}: ${isTeam(m.home) ? m.home : m.home} vs ${isTeam(m.away) ? m.away : m.away}, ${fmtKick(m.kickoff)}`}
                >
                  <span class={`bk-slot ${isTeam(m.home) ? "is-team" : "is-ph"}`}>
                    {isTeam(m.home)
                      ? <><TeamFlag team={m.home} size={16} /><span class="bk-name">{m.home}</span></>
                      : <span class="bk-ph">{m.home}</span>}
                  </span>
                  <span class={`bk-slot ${isTeam(m.away) ? "is-team" : "is-ph"}`}>
                    {isTeam(m.away)
                      ? <><TeamFlag team={m.away} size={16} /><span class="bk-name">{m.away}</span></>
                      : <span class="bk-ph">{m.away}</span>}
                  </span>
                  <span class="bk-kick">{shortDate(m.kickoff)}</span>
                </a>
              ))}
            </div>
            {ri < rounds.length - 1 && (
              <div class="bk-gap" aria-hidden="true">
                <svg width={GAP_W} height={H} viewBox={`0 0 ${GAP_W} ${H}`} role="presentation">
                  <path d={gapPaths[ri]} />
                </svg>
              </div>
            )}
          </>
        ))}

        <!-- Final → Champion apex. -->
        <div class="bk-gap bk-gap-champ" aria-hidden="true">
          <svg width={GAP_W} height={H} viewBox={`0 0 ${GAP_W} ${H}`} role="presentation">
            <path d={`M0 ${r2(H / 2)}H${GAP_W}`} />
          </svg>
        </div>
        <div class="bk-round" style={`width:${CHAMP_W}px;height:${H}px;`}>
          <div class={`bk-champ ${champion ? "is-won" : ""}`} style={`top:${r2(H / 2)}px;`}>
            <span class="bk-trophy" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 4h8v3a4 4 0 0 1-8 0V4z" />
                <path d="M8 5H5.5A2.5 2.5 0 0 0 8 8.5" />
                <path d="M16 5h2.5A2.5 2.5 0 0 1 16 8.5" />
                <path d="M12 11v3M9.5 17h5M10 14h4" />
              </svg>
            </span>
            {champion
              ? <span class="bk-champ-team"><TeamFlag team={champion} size={20} /><b>{champion}</b></span>
              : <span class="bk-champ-team"><b>Champion</b><small>to be decided</small></span>}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Screen-reader linearisation of the visual board. -->
  <div class="sr-only">
    <h2>Bracket as a list</h2>
    {rounds.map((r) => (
      <section>
        <h3>{r.label}</h3>
        <ul>
          {r.ties.map((m) => (
            <li>{m.home} versus {m.away}, {fmtKick(m.kickoff)}{m.venue ? `, ${m.venue}` : ""}.</li>
          ))}
        </ul>
      </section>
    ))}
  </div>

  {thirdPlace && (
    <section class="panel bk-third" style="margin-top:1.6rem;">
      <div class="section-head"><h2>Third-place play-off</h2><span class="rule"></span></div>
      <a class="bk-tie standalone" data-stage="3RD" href={`/matches/${thirdPlace.id}`} aria-label={`Third-place play-off: ${thirdPlace.home} vs ${thirdPlace.away}, ${fmtKick(thirdPlace.kickoff)}`}>
        <span class={`bk-slot ${isTeam(thirdPlace.home) ? "is-team" : "is-ph"}`}>
          {isTeam(thirdPlace.home)
            ? <><TeamFlag team={thirdPlace.home} size={16} /><span class="bk-name">{thirdPlace.home}</span></>
            : <span class="bk-ph">{thirdPlace.home}</span>}
        </span>
        <span class={`bk-slot ${isTeam(thirdPlace.away) ? "is-team" : "is-ph"}`}>
          {isTeam(thirdPlace.away)
            ? <><TeamFlag team={thirdPlace.away} size={16} /><span class="bk-name">{thirdPlace.away}</span></>
            : <span class="bk-ph">{thirdPlace.away}</span>}
        </span>
        <span class="bk-kick"><LocalTime iso={thirdPlace.kickoff} fmt="datetime" />{thirdPlace.venue ? ` · ${thirdPlace.venue}` : ""}</span>
      </a>
    </section>
  )}
</Base>

<style>
  .not-started {
    display: flex; align-items: flex-start; gap: 0.7rem;
    border-left: 3px solid var(--warn); line-height: 1.55;
  }
  .ns-dot {
    margin-top: 0.45rem; width: 0.6rem; height: 0.6rem; flex: none; border-radius: 999px;
    background: var(--warn); box-shadow: 0 0 0 4px var(--warn-soft);
  }

  /* Horizontal scroll wrapper so the wide board never breaks the page on mobile. */
  .bk-scroll {
    margin-top: 1.4rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 0.6rem;
  }
  .bk-stage { display: flex; flex-direction: column; }

  /* Headers row — same column/gap widths as the board so labels sit over columns. */
  .bk-heads { display: flex; align-items: end; margin-bottom: 0.55rem; }
  .bk-head {
    flex: none; display: flex; align-items: baseline; gap: 0.4rem;
    padding: 0 0.1rem 0.3rem; border-bottom: 2px solid var(--stage-c, var(--border-strong));
  }
  .bk-head-gap { flex: none; }
  .bk-head-label { font-size: 0.85rem; font-weight: 700; color: var(--fg); }
  .bk-head-n {
    font-size: 0.7rem; font-weight: 700; color: var(--muted-2);
    background: var(--surface-2); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 0.02rem 0.4rem; font-variant-numeric: tabular-nums;
  }

  /* Board: each round is a fixed-height relative box; ties are absolutely placed
     at their computed y so the SVG elbows in the gaps line up exactly. */
  .bk-board { display: flex; align-items: stretch; }
  .bk-round { position: relative; flex: none; }
  .bk-gap { flex: none; width: 46px; }
  .bk-gap svg { display: block; }
  .bk-gap path { fill: none; stroke: var(--border-strong); stroke-width: 2; }
  .bk-gap-champ path { stroke: var(--stage-final); stroke-dasharray: 4 4; opacity: 0.8; }

  .bk-tie {
    position: absolute; left: 0; right: 0;
    transform: translateY(-50%);
    display: grid; gap: 0.05rem;
    height: 62px;
    box-sizing: border-box;
    text-decoration: none; color: inherit;
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--stage-c, var(--border-strong));
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.5rem;
    box-shadow: var(--shadow);
    transition: border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease);
  }
  .bk-tie:hover {
    text-decoration: none;
    border-color: var(--border-strong);
    background: var(--surface-2);
    transform: translateY(-50%) scale(1.015);
    z-index: 2;
  }
  .bk-tie:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; z-index: 3; }

  .bk-slot { display: flex; align-items: center; gap: 0.4rem; min-width: 0; line-height: 1.1; }
  .bk-name {
    font-weight: 700; font-size: 0.82rem; color: var(--fg);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .bk-ph {
    font-size: 0.76rem; font-weight: 700; letter-spacing: 0.01em; color: var(--muted-2);
    font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .bk-kick {
    font-size: 0.68rem; color: var(--muted-2); font-variant-numeric: tabular-nums;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* Champion apex node. */
  .bk-champ {
    position: absolute; left: 0; right: 0; transform: translateY(-50%);
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.7rem 0.8rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--stage-final);
    background: linear-gradient(180deg, rgba(255,216,77,0.12), var(--surface));
    box-shadow: var(--shadow-md);
  }
  .bk-trophy { display: inline-flex; align-items: center; color: var(--stage-final); }
  .bk-champ-team { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; }
  .bk-champ-team b { font-size: 0.95rem; color: var(--fg); }
  .bk-champ-team small { font-size: 0.7rem; color: var(--muted-2); }
  .bk-champ.is-won .bk-champ-team { flex-direction: row; align-items: center; gap: 0.45rem; }

  /* Per-round accent tokens (header underline + tie left border + champion). */
  [data-stage="R32"]   { --stage-c: var(--stage-r32); }
  [data-stage="R16"]   { --stage-c: var(--stage-r16); }
  [data-stage="QF"]    { --stage-c: var(--stage-qf); }
  [data-stage="SF"]    { --stage-c: var(--stage-sf); }
  [data-stage="FINAL"] { --stage-c: var(--stage-final); }
  [data-stage="3RD"]   { --stage-c: var(--stage-3rd); }
  [data-stage="CHAMP"] { --stage-c: var(--stage-final); }

  /* Third-place play-off renders as a single standalone card (static, not placed). */
  .bk-third .section-head { margin-bottom: 0.9rem; }
  .bk-tie.standalone {
    position: static; transform: none; height: auto; max-width: 340px;
    display: grid; gap: 0.25rem;
  }
  .bk-tie.standalone:hover { transform: none; }
  .bk-tie.standalone .bk-slot + .bk-slot { border-top: 1px dashed var(--border-soft); padding-top: 0.25rem; }

  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
</style>
