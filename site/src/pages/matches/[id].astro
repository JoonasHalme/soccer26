---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import ProbBar from "../../components/ProbBar.astro";
import StageChip from "../../components/StageChip.astro";
import NewsItem from "../../components/NewsItem.astro";
import BookmakerOdds from "../../components/BookmakerOdds.astro";
import LocalTime from "../../components/LocalTime.astro";
import { loadFixtures, loadBets, loadPredictions, loadNews, selectionLabel, pct1, flagCode, teamSlug, matchOutcome, loadPredictionArchive, publishedProbs, latestBookUpdate } from "../../lib/data";

export async function getStaticPaths() {
  const { matches } = loadFixtures();
  return matches.map((m) => ({ params: { id: m.id } }));
}

const { id } = Astro.params;
const { matches } = loadFixtures();
const { bets } = loadBets();
const { predictions } = loadPredictions();
const match = matches.find((m) => m.id === id);
const pred = predictions.find((p) => p.match_id === id);
const matchBets = bets.filter((b) => b.match_id === id);

const analyses = await getCollection("matches", (entry) => entry.data.match_id === id);
const analysis = analyses[0];
// Guard: only render the markdown analysis when a content entry actually exists.
// A match with no analysis (32 of 104 pages) must never reach render() — otherwise
// the build would crash on undefined.render(). When absent, Analysis stays null and
// the analysis block is skipped (fallback handled in the template below).
let Analysis = null;
if (analysis) {
  Analysis = (await render(analysis)).Content;
}

if (!match) {
  return Astro.redirect("/matches");
}

const matchTeams = [match.home, match.away];
const matchNews = loadNews()
  .items.filter((n) => n.teams.some((t) => matchTeams.includes(t)))
  .slice(0, 8);

const probPct = (p: number) => `${(p * 100).toFixed(1)}%`;
const resultClass = (r?: string | null) =>
  r === "WIN" ? "win" : r === "LOSS" ? "loss" : r ? "" : "open";

// The PUBLISHED call (market-blended where priced) drives the headline; the raw
// model stays available for the "model vs market" breakdown below.
const p = pred ? publishedProbs(pred) : undefined;
let lean: "home" | "draw" | "away" | null = null;
if (p) {
  const mx = Math.max(p.home, p.draw, p.away);
  lean = mx === p.home ? "home" : mx === p.away ? "away" : "draw";
}
// Show the breakdown only when we actually blended against a priced market.
// Precomputed into formatted rows so the template stays simple JSX.
const blend = (pred?.forecast?.blended && pred.market) ? {
  wModel: Math.round(pred.forecast.weight * 100),
  wMarket: Math.round((1 - pred.forecast.weight) * 100),
  rows: [
    { label: "Raw model", call: false,
      home: probPct(pred.probabilities.home), draw: probPct(pred.probabilities.draw), away: probPct(pred.probabilities.away) },
    { label: "Market (de-vig)", call: false,
      home: pred.market.home != null ? probPct(pred.market.home) : "—",
      draw: pred.market.draw != null ? probPct(pred.market.draw) : "—",
      away: pred.market.away != null ? probPct(pred.market.away) : "—" },
    { label: "Our call", call: true,
      home: probPct(pred.forecast.home), draw: probPct(pred.forecast.draw), away: probPct(pred.forecast.away) },
  ],
} : null;
const ratingGap = pred ? Math.round(pred.ratings.home - pred.ratings.away) : null;
const hasScore = match.score?.home != null && match.score?.away != null;

// Post-match "we said X → result Y" data: the frozen PRE-KICKOFF prediction (from the
// archive, since predictions.json drops finished matches) vs the actual outcome.
const outcome = matchOutcome(match);
const arch = loadPredictionArchive()[id];
const postMatch = outcome && arch ? (() => {
  const labels: Record<string, string> = { home: `${match.home} win`, draw: "Draw", away: `${match.away} win` };
  const top = (["home", "draw", "away"] as const).reduce((a, b) => (arch[b] > arch[a] ? b : a));
  return {
    probs: arch,
    outcome, top,
    correct: top === outcome,
    actualProb: arch[outcome],
    label: labels,
    settledBets: matchBets.filter((b) => b.result),
  };
})() : null;
---
<Base title={`${match.home} vs ${match.away} — Soccer 26`} ogImage={`/og/match/${match.id}.png`}>
  <p style="margin-bottom: 0.9rem;"><a href="/matches" class="subtle">← Match centre</a></p>

  <section class="match-hero">
    <div class="mh-meta">
      <StageChip stage={match.stage} group={match.group} />
      <span class="mh-dot" aria-hidden="true">·</span>
      <LocalTime iso={match.kickoff} fmt="datetime" />
      <span class="mh-dot" aria-hidden="true">·</span>
      <span>{match.venue ?? "Venue TBD"}</span>
    </div>

    <div class="mh-teams">
      <div class={`mh-team ${lean === "home" ? "fav" : ""}`}>
        {flagCode(match.home)
          ? <a class="mh-name" href={`/team/${teamSlug(match.home)}`}>{match.home}</a>
          : <span class="mh-name">{match.home}</span>}
        {pred && <span class="mh-rating">Elo {Math.round(pred.ratings.home)}</span>}
      </div>
      <div class="mh-center">
        {hasScore ? (
          <span class="mh-score">{match.score!.home}<span class="mh-dash">–</span>{match.score!.away}</span>
        ) : (
          <span class="mh-vs">VS</span>
        )}
        {ratingGap != null && (
          <span class="mh-gap">{ratingGap === 0 ? "level" : `${ratingGap > 0 ? "+" : ""}${ratingGap} Elo`}</span>
        )}
      </div>
      <div class={`mh-team right ${lean === "away" ? "fav" : ""}`}>
        {flagCode(match.away)
          ? <a class="mh-name" href={`/team/${teamSlug(match.away)}`}>{match.away}</a>
          : <span class="mh-name">{match.away}</span>}
        {pred && <span class="mh-rating">Elo {Math.round(pred.ratings.away)}</span>}
      </div>
    </div>

    {pred && p && (
      <div class="mh-prob">
        <ProbBar
          home={p.home}
          draw={p.draw}
          away={p.away}
          homeLabel={match.home}
          awayLabel={match.away}
        />
      </div>
    )}
  </section>

  {postMatch && (
    <section class={`panel postmatch ${postMatch.correct ? "is-correct" : "is-miss"}`} style="margin-top: 1.6rem;">
      <div class="pm-head">
        <span class={`pm-verdict ${postMatch.correct ? "ok" : "miss"}`}>
          {postMatch.correct ? "Top pick ✓ correct" : "Top pick ✗ missed"}
        </span>
        <span class="pm-result">Result: {match.score!.home}–{match.score!.away} · {postMatch.label[postMatch.outcome]}</span>
      </div>
      <p class="pm-line">
        The model's pre-kickoff call was <strong>{postMatch.label[postMatch.top]}</strong> at
        <strong> {pct1(postMatch.probs[postMatch.top] * 100)}%</strong>, and it gave the actual
        result (<strong>{postMatch.label[postMatch.outcome]}</strong>)
        <strong> {pct1(postMatch.actualProb * 100)}%</strong>.
      </p>
      <div class="pm-probs" aria-hidden="true">
        <span class={postMatch.outcome === "home" ? "hit" : ""}>{match.home} {pct1(postMatch.probs.home * 100)}%</span>
        <span class={postMatch.outcome === "draw" ? "hit" : ""}>Draw {pct1(postMatch.probs.draw * 100)}%</span>
        <span class={postMatch.outcome === "away" ? "hit" : ""}>{match.away} {pct1(postMatch.probs.away * 100)}%</span>
      </div>
      {postMatch.settledBets.length > 0 && (
        <p class="pm-bets">
          {postMatch.settledBets.map((b) => (
            <span class={`pm-bet ${b.result === "WIN" ? "ok" : b.result === "LOSS" ? "miss" : ""}`}>
              {selectionLabel(b.selection, match.home, match.away)} → {b.result}{typeof b.pnl === "number" ? ` (${b.pnl >= 0 ? "+" : "−"}${Math.abs(b.pnl).toFixed(2)})` : ""}
            </span>
          ))}
        </p>
      )}
    </section>
  )}

  {pred && p && (
    <section style="margin-top: 1.6rem;">
      <div class="grid cols-3 keymetrics">
        <div class="panel stat-card"><div class="stat-label">{match.home} win</div><div class="stat-value">{probPct(p.home)}</div></div>
        <div class="panel stat-card tone-mag"><div class="stat-label">Draw</div><div class="stat-value">{probPct(p.draw)}</div></div>
        <div class="panel stat-card tone-warn"><div class="stat-label">{match.away} win</div><div class="stat-value">{probPct(p.away)}</div></div>
      </div>

      <div class="goalstats">
        <span class="gs-item"><span class="gs-k">xG</span><span class="gs-v">{p.expected_goals.home.toFixed(2)} – {p.expected_goals.away.toFixed(2)}</span></span>
        <span class="gs-item"><span class="gs-k">Over 2.5</span><span class="gs-v">{probPct(p.over_2_5)}</span></span>
        <span class="gs-item"><span class="gs-k">Under 2.5</span><span class="gs-v">{probPct(p.under_2_5)}</span></span>
        <span class="gs-item"><span class="gs-k">BTTS</span><span class="gs-v">{probPct(p.btts_yes)}</span></span>
      </div>

      {blend && (
        <div class="panel mvm" style="margin-top: 1.1rem;">
          <div class="section-head">
            <h2>Model vs market</h2>
            <span class="count">our call = {blend.wModel}% model + {blend.wMarket}% market here</span>
            <span class="rule"></span>
          </div>
          <p class="subtle mvm-note">
            The raw Elo+Poisson model can't see squad quality and is mis-scaled across
            confederations, so on lopsided matchups it disagrees sharply with a deep
            multi-book market. We publish a blend, and trust the model <em>less</em> the more
            it disagrees — so the model's share above is lower for the games where it strays
            furthest. The <a href="/divergence">divergence tracker</a> shows the raw gaps.
          </p>
          <div class="table-wrap">
            <table class="mvm-table table--cards">
              <thead>
                <tr><th>1X2</th><th class="num">{match.home}</th><th class="num">Draw</th><th class="num">{match.away}</th></tr>
              </thead>
              <tbody>
                {blend.rows.map((row) => (
                  <tr class={row.call ? "mvm-call" : undefined}>
                    <td data-label="row">{row.call ? <strong>{row.label}</strong> : row.label}</td>
                    <td class="num" data-label="Home">{row.home}</td>
                    <td class="num" data-label="Draw">{row.draw}</td>
                    <td class="num" data-label="Away">{row.away}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </section>
  )}

  {pred?.asian && (
    <section class="panel" style="margin-top: 1.6rem;">
      <div class="section-head">
        <h2>Asian markets</h2>
        <span class="count">model probabilities · derived from the score matrix</span>
        <span class="rule"></span>
      </div>
      <p class="subtle" style="margin:0 0 1rem; font-size:0.88rem;">
        Handicaps from {match.home}'s side ({"−"}0.5 = must win outright; +0.5 = covers unless they lose).
        Half-lines can't push; whole lines can. No AH odds sourced yet, so these are probabilities, not edges.
      </p>
      <div class="asian-grid">
        <div class="table-wrap">
          <table>
            <thead><tr><th>Handicap</th><th class="num">{match.home}</th><th class="num">Push</th><th class="num">{match.away}</th></tr></thead>
            <tbody>
              {pred.asian.handicaps.map((h) => (
                <tr>
                  <td><strong>{h.line > 0 ? `+${h.line}` : h.line}</strong></td>
                  <td class="num">{probPct(h.home)}</td>
                  <td class="num">{h.push ? probPct(h.push) : "—"}</td>
                  <td class="num">{probPct(h.away)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Total</th><th class="num">Over</th><th class="num">Under</th></tr></thead>
            <tbody>
              {pred.asian.totals.map((t) => (
                <tr>
                  <td><strong>{t.line}</strong></td>
                  <td class="num">{probPct(t.over)}</td>
                  <td class="num">{probPct(t.under)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  {pred?.derived && (
    <section class="panel" style="margin-top: 1.6rem;">
      <div class="section-head">
        <h2>More markets</h2>
        <span class="count">model probabilities · derived from the score matrix</span>
        <span class="rule"></span>
      </div>
      <p class="subtle" style="margin:0 0 1rem; font-size:0.88rem;">
        Double chance, Draw-No-Bet and the likeliest exact scores, summed from the same
        Dixon-Coles scoreline distribution as the 1X2 numbers. No odds sourced for these,
        so they're probabilities, not edges.
      </p>
      <div class="asian-grid">
        <div class="table-wrap">
          <table class="table--cards">
            <thead><tr><th>Double chance</th><th class="num">Prob</th></tr></thead>
            <tbody>
              <tr><td data-label="Double chance"><strong>{match.home} or Draw</strong></td><td class="num" data-label="Prob">{probPct(pred.derived.double_chance.home_or_draw)}</td></tr>
              <tr><td data-label="Double chance"><strong>Draw or {match.away}</strong></td><td class="num" data-label="Prob">{probPct(pred.derived.double_chance.draw_or_away)}</td></tr>
              <tr><td data-label="Double chance"><strong>{match.home} or {match.away}</strong> <span class="subtle">(no draw)</span></td><td class="num" data-label="Prob">{probPct(pred.derived.double_chance.home_or_away)}</td></tr>
              <tr><td data-label="Draw-No-Bet"><strong>DNB — {match.home}</strong></td><td class="num" data-label="Prob">{probPct(pred.derived.dnb.home)}</td></tr>
              <tr><td data-label="Draw-No-Bet"><strong>DNB — {match.away}</strong></td><td class="num" data-label="Prob">{probPct(pred.derived.dnb.away)}</td></tr>
            </tbody>
          </table>
        </div>
        <div class="table-wrap">
          <table class="table--cards">
            <thead><tr><th>Likeliest score</th><th class="num">Prob</th></tr></thead>
            <tbody>
              {pred.derived.correct_scores.map((c) => (
                <tr>
                  <td data-label="Likeliest score"><strong class="cs-score">{c.home}–{c.away}</strong></td>
                  <td class="num" data-label="Prob">{probPct(c.prob)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>
  )}

  {pred && pred.edges.length > 0 && (
    <section class="panel" style="margin-top: 1.6rem;">
      <div class="section-head"><h2>Edges vs market</h2><span class="count">value spotted</span><span class="rule"></span></div>
      <div class="table-wrap">
        <table class="table--cards">
          <thead><tr><th>Selection</th><th class="num">Our call</th><th class="num">Market</th><th class="num">Odds</th><th class="num">Edge</th></tr></thead>
          <tbody>
            {pred.edges.map((e) => (
              <tr>
                <td><strong>{selectionLabel(e.selection, match.home, match.away)}</strong></td>
                <td class="num" data-label="Our call">{probPct(e.model_prob)}{e.model_raw_prob != null && <span class="raw-sub" title="Pre-blend anchored-model probability"> · raw {probPct(e.model_raw_prob)}</span>}</td>
                <td class="num" data-label="Market">{probPct(e.implied_prob)}</td>
                <td class="num" data-label="Odds">{e.odds_decimal.toFixed(2)}</td>
                <td class="num" data-label="Edge"><span class={`badge ${e.edge_pct >= 8 ? "badge-edge" : "badge-warn"}`}>+{pct1(e.edge_pct)}%</span>{e.raw_edge_pct != null && <span class="raw-sub" title="Raw model−market gap; staked edge = trust × raw gap"> raw +{pct1(e.raw_edge_pct)}%</span>}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <section class="panel" style="margin-top: 1.6rem;">
    <div class="section-head">
      <h2>Bookmaker odds</h2>
      <span class="count">
        line-shopping · {match.books?.length ?? 0} books
        {latestBookUpdate(match) && <> · as of <LocalTime iso={latestBookUpdate(match)} fmt="datetime" /></>}
      </span>
      <span class="rule"></span>
    </div>
    <BookmakerOdds books={match.books} homeLabel={match.home} awayLabel={match.away} />
  </section>

  {Analysis && (
    <section class="panel" style="margin-top: 1.6rem;">
      <div class="section-head"><h2>Analysis</h2><span class="rule"></span></div>
      {analysis?.data.summary && <p class="lead">{analysis.data.summary}</p>}
      <div class="prose"><Analysis /></div>
      {analysis && analysis.data.verify_before_betting.length > 0 && (
        <div class="verify">
          <h3>Verify before betting</h3>
          <ul>
            {analysis.data.verify_before_betting.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      )}
      {analysis?.data.last_updated && (
        <p class="meta" style="font-size: 0.8rem; margin-bottom:0;">Updated {analysis.data.last_updated}</p>
      )}
    </section>
  )}

  {pred && pred.edges.length === 0 && !Analysis && (
    <p class="meta" style="margin-top:1.2rem;">No value edges vs current market odds, and no written analysis yet.</p>
  )}

  <section class="panel" style="margin-top: 1.6rem;">
    <div class="section-head">
      <h2>Team news</h2>
      <span class="count">{match.home} · {match.away}</span>
      <span class="rule"></span>
    </div>
    {matchNews.length === 0 ? (
      <p class="subtle" style="margin:0">No recent news mentioning {match.home} or {match.away}.</p>
    ) : (
      <div class="news-list">
        {matchNews.map((item) => <NewsItem item={item} highlightTeams={matchTeams} />)}
      </div>
    )}
  </section>

  <section class="panel" style="margin-top: 1.6rem;">
    <div class="section-head"><h2>Bets on this match</h2><span class="rule"></span></div>
    {matchBets.length === 0 ? (
      <p class="subtle" style="margin:0">No bets placed.</p>
    ) : (
      <div class="table-wrap">
        <table class="table--cards">
          <thead><tr><th>Market</th><th>Selection</th><th class="num">Odds</th><th class="num">Stake</th><th class="num">CLV</th><th>Result</th><th class="num">P/L</th></tr></thead>
          <tbody>
            {matchBets.map((b) => (
              <tr>
                <td>{b.market}</td>
                <td data-label="Selection">{selectionLabel(b.selection, match.home, match.away)}</td>
                <td class="num" data-label="Odds">{b.odds_decimal.toFixed(2)}</td>
                <td class="num" data-label="Stake">{b.stake.toFixed(2)}</td>
                <td class={`num ${typeof b.clv_pct === "number" ? (b.clv_pct > 0 ? "pos" : b.clv_pct < 0 ? "neg" : "") : ""}`} data-label="CLV">
                  {typeof b.clv_pct === "number" ? `${b.clv_pct >= 0 ? "+" : ""}${b.clv_pct.toFixed(1)}%` : "—"}
                </td>
                <td data-label="Result"><span class={`pill ${resultClass(b.result)}`}>{b.result ?? "OPEN"}</span></td>
                <td class={`num ${b.pnl != null && b.pnl >= 0 ? "pos" : "neg"}`} data-label="P/L">{b.pnl?.toFixed(2) ?? "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </section>
</Base>

<style>
  .match-hero {
    position: relative; overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background:
      radial-gradient(110% 130% at 0% 0%, rgba(43,182,255,0.12), transparent 50%),
      radial-gradient(110% 130% at 100% 0%, rgba(240,165,42,0.12), transparent 50%),
      linear-gradient(180deg, var(--surface-2), var(--surface));
    padding: 1.6rem 1.8rem 1.7rem;
    box-shadow: var(--shadow-lg);
  }
  .mh-meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
    color: var(--muted); font-size: 0.88rem; margin-bottom: 1.2rem;
  }
  .mh-dot { color: var(--border-strong); }

  .mh-teams {
    display: grid; grid-template-columns: 1fr auto 1fr;
    align-items: center; gap: 1rem;
  }
  .mh-team { display: flex; flex-direction: column; gap: 0.3rem; min-width: 0; }
  .mh-team.right { text-align: right; align-items: flex-end; }
  .mh-name {
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(1.2rem, 3.4vw, 1.9rem); letter-spacing: -0.025em; line-height: 1.05;
    color: var(--fg);
  }
  .mh-team:not(.fav) .mh-name { color: var(--muted); }
  a.mh-name { text-decoration: none; }
  a.mh-name:hover { color: var(--accent); text-decoration: underline; }
  .mh-rating {
    font-size: 0.78rem; font-weight: 700; color: var(--muted-2);
    text-transform: uppercase; letter-spacing: 0.05em; font-variant-numeric: tabular-nums;
  }
  .mh-team.fav .mh-rating { color: var(--accent); }

  .mh-center { display: flex; flex-direction: column; align-items: center; gap: 0.35rem; }
  .mh-vs {
    font-family: var(--font-mono); font-weight: 600; font-size: 0.8rem;
    letter-spacing: 0.1em; color: var(--muted-2);
    border: 1px solid var(--border-strong); border-radius: var(--radius-sm); padding: 0.25rem 0.7rem;
  }
  .mh-score { font-family: var(--font-mono); font-weight: 600; font-size: 1.9rem; font-variant-numeric: tabular-nums slashed-zero; }
  .mh-dash { color: var(--muted-2); margin: 0 0.2rem; }
  .mh-gap {
    font-size: 0.72rem; font-weight: 700; color: var(--muted);
    background: var(--surface-3); border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm); padding: 0.1rem 0.5rem; white-space: nowrap;
  }

  .mh-prob { margin-top: 1.5rem; }

  /* Post-match "we said X → result Y" card */
  .postmatch { border-left: 3px solid var(--border-strong); }
  .postmatch.is-correct { border-left-color: var(--accent); }
  .postmatch.is-miss { border-left-color: var(--bad); }
  .pm-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem 1rem; margin-bottom: 0.6rem; }
  .pm-verdict { font-family: var(--font-mono); font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
  .pm-verdict.ok { color: var(--accent); }
  .pm-verdict.miss { color: var(--bad); }
  .pm-result { font-weight: 700; color: var(--fg); }
  .pm-line { margin: 0; color: var(--muted); line-height: 1.6; }
  .pm-line strong { color: var(--fg); }
