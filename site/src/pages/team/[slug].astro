---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import GroupCard from "../../components/GroupCard.astro";
import MatchCard from "../../components/MatchCard.astro";
import NewsItem from "../../components/NewsItem.astro";
import TeamFlag from "../../components/TeamFlag.astro";
import FollowButton from "../../components/FollowButton.astro";
import LocalTime from "../../components/LocalTime.astro";
import Squad from "../../components/Squad.astro";
import TeamForm from "../../components/TeamForm.astro";
import {
  loadFixtures, loadPredictions, loadNews, loadSquads, loadForm,
  computeStandings, allEdges, selectionLabel, teamSlug, teamGroups, pct1,
} from "../../lib/data";

// One static page per seeded team (48), enumerated from the fixtures groups.
export function getStaticPaths() {
  const { groups } = loadFixtures();
  return teamGroups(groups).map(({ team, group }) => ({
    params: { slug: teamSlug(team) },
    props: { team, group },
  }));
}

const { team, group } = Astro.props;

const { matches, groups } = loadFixtures();
const { predictions } = loadPredictions();
const news = loadNews();

const standings = computeStandings(matches, groups);
const groupRows = standings[group] ?? [];
const row = groupRows.find((r) => r.team === team);
const position = groupRows.findIndex((r) => r.team === team) + 1;
const groupStarted = groupRows.reduce((s, r) => s + r.played, 0) > 0;

// Every fixture the team appears in (group stage now; knockout slots fill later).
const fixtures = matches
  .filter((m) => m.home === team || m.away === team)
  .sort((a, b) => (a.kickoff ?? "").localeCompare(b.kickoff ?? ""));
const predById = new Map(predictions.map((p) => [p.match_id, p]));
const analyzedIds = new Set((await getCollection("matches")).map((a) => a.data.match_id));

// Value edges in this team's matches, best edge first.
const edges = allEdges(predictions, matches)
  .filter((e) => e.home === team || e.away === team)
  .sort((a, b) => b.edge_pct - a.edge_pct);

const squadsFile = loadSquads();
const squad = squadsFile.teams[team];

const teamForm = loadForm().teams[team];

const teamNews = news.items.filter((n) => n.teams.includes(team));

const title = `${team} — World Cup 2026 fixtures, form & value edges | Soccer 26`;
const description = `${team}'s FIFA World Cup 2026 squad, schedule (Group ${group}), model win probabilities, value betting edges vs the de-vigged market, and the latest ${team} team news. Transparent, calibration-first analysis.`;

---
<Base title={title} description={description} ogImage={`/og/team/${teamSlug(team)}.png`}>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/groups">Groups</a> <span aria-hidden="true">/</span>
    <a href={`/group/${group.toLowerCase()}`}>Group {group}</a> <span aria-hidden="true">/</span>
    <span aria-current="page">{team}</span>
  </nav>

  <section class="tm-hero">
    <TeamFlag team={team} size={56} />
    <div class="tm-hero-body">
      <p class="eyebrow">FIFA World Cup 2026 · <a href={`/group/${group.toLowerCase()}`} class="grp-link">Group {group}</a></p>
      <div class="tm-headrow">
        <h1>{team}</h1>
        <FollowButton team={team} />
      </div>
      <p class="subtle tm-line">
        {groupStarted && row
          ? <>Currently <b>{position}{["th","st","nd","rd"][(position % 10 > 3 || [11,12,13].includes(position)) ? 0 : position % 10]}</b> in Group {group} · {row.points} pt{row.points === 1 ? "" : "s"} from {row.played} played</>
          : <>Group {group} · the tournament begins 11 June — fixtures, model probabilities and edges below.</>}
      </p>
    </div>
    <div class="tm-stat">
      <span class="tm-stat-n">{fixtures.length}</span>
      <span class="tm-stat-l">fixtures</span>
    </div>
    <div class={`tm-stat ${edges.length ? "accent" : ""}`}>
      <span class="tm-stat-n">{edges.length}</span>
      <span class="tm-stat-l">value edges</span>
    </div>
  </section>

  <section class="tm-section">
    <div class="section-head"><h2>Fixtures</h2><span class="count">{fixtures.length} match{fixtures.length === 1 ? "" : "es"}</span><span class="rule"></span></div>
    {fixtures.length === 0 ? (
      <div class="panel"><p class="subtle" style="margin:0">No fixtures found for {team}.</p></div>
    ) : (
      <div class="cards-grid">
        {fixtures.map((m) => (
          <MatchCard match={m} pred={predById.get(m.id)} analyzed={analyzedIds.has(m.id)} />
        ))}
      </div>
    )}
  </section>

  {teamForm && teamForm.matches.length > 0 && (
    <section class="tm-section">
      <div class="section-head"><h2>Road to the World Cup</h2><span class="count">recent form</span><span class="rule"></span></div>
      <div class="panel">
        <TeamForm form={teamForm} team={team} />
      </div>
    </section>
  )}

  {squad && squad.players.length > 0 && (
    <section class="tm-section">
      <div class="section-head"><h2>Squad</h2><span class="count">{squad.players.length} players</span><span class="rule"></span></div>
      <Squad squad={squad} />
      <p class="subtle" style="margin:0.8rem 0 0; font-size:0.78rem;">
        Squad via <a href="https://en.wikipedia.org/wiki/2026_FIFA_World_Cup_squads" rel="noopener noreferrer" target="_blank">Wikipedia</a>
        (CC BY-SA){squadsFile.updated ? ` · as of ${squadsFile.updated}` : ""}.
      </p>
    </section>
  )}

  {edges.length > 0 && (
    <section class="tm-section">
      <div class="section-head"><h2>Value edges</h2><span class="count">model vs market</span><span class="rule"></span><a href="/edges" class="see-all">All edges →</a></div>
      <div class="table-wrap">
        <table class="tm-edges table--cards">
          <thead>
            <tr><th>Match</th><th>Selection</th><th class="num">Edge</th><th>Best price</th><th>Kickoff</th></tr>
          </thead>
          <tbody>
            {edges.map((e) => (
              <tr>
                <td><a href={`/matches/${e.match_id}`}>{e.home} vs {e.away}</a></td>
                <td data-label="Selection">{selectionLabel(e.selection, e.home, e.away)}</td>
                <td class="num" data-label="Edge"><span class="badge badge-edge">+{pct1(e.edge_pct)}%</span></td>
                <td data-label="Best price">{e.best_odds ? <span class="best"><b>{e.best_odds.toFixed(2)}</b> <span class="bk">{e.best_book}</span></span> : <span class="subtle">{e.odds_decimal?.toFixed(2) ?? "—"}</span>}</td>
                <td class="meta" data-label="Kickoff"><LocalTime iso={e.kickoff} fmt="datetime" /></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <section class="tm-section">
    <div class="section-head"><h2>Group {group} table</h2><span class="rule"></span><a href={`/group/${group.toLowerCase()}`} class="see-all">Group page →</a></div>
    <GroupCard letter={group} rows={groupRows} full highlight={team} />
  </section>

  {teamNews.length > 0 && (
    <section class="tm-section">
      <div class="section-head"><h2>{team} team news</h2><span class="count">RSS</span><span class="rule"></span></div>
      <div class="news-grid">
        {teamNews.slice(0, 8).map((item) => <NewsItem item={item} highlightTeams={[team]} />)}
      </div>
    </section>
  )}
</Base>

<style>
  .crumbs { font-size: 0.82rem; color: var(--muted-2); margin-bottom: 0.9rem; display: flex; gap: 0.45rem; flex-wrap: wrap; }
  .crumbs a { color: var(--muted); text-decoration: none; }
  .crumbs a:hover { color: var(--accent); text-decoration: underline; }

  .tm-hero {
    display: flex; align-items: center; gap: 1.1rem; flex-wrap: wrap;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    padding: var(--s-5) var(--s-5);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }
  .tm-hero-body { flex: 1; min-width: 200px; }
  .tm-headrow { display: flex; align-items: center; gap: 0.9rem; flex-wrap: wrap; }
  .tm-hero-body h1 { margin: 0.15rem 0 0.2rem; }
  .tm-line { margin: 0; }
  .tm-line b { color: var(--fg); }
  .grp-link { color: var(--accent); text-decoration: none; }
  .grp-link:hover { text-decoration: underline; }

  .tm-stat { display: flex; flex-direction: column; align-items: center; gap: 0.05rem; padding: 0 0.6rem; }
  .tm-stat-n { font-family: var(--font-mono); font-weight: 600; font-size: 1.55rem; color: var(--fg); font-variant-numeric: tabular-nums slashed-zero; line-height: 1; }
  .tm-stat.accent .tm-stat-n { color: var(--accent); }
  .tm-stat-l { font-size: 0.72rem; color: var(--muted-2); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }

  .tm-section { margin-top: 2.1rem; }
  .cards-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); }
  .news-grid { display: grid; gap: 0.7rem; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); }
  .see-all { font-size: 0.85rem; font-weight: 600; white-space: nowrap; }

  .table-wrap { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1px solid var(--border-soft); border-radius: var(--radius-sm); }
  .tm-edges { border-collapse: collapse; width: 100%; font-size: 0.9rem; }
  .tm-edges th, .tm-edges td { text-align: left; padding: 0.6rem 0.8rem; border-bottom: 1px solid var(--border-soft); white-space: nowrap; }
  .tm-edges thead th { color: var(--muted-2); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .tm-edges tbody tr:last-child td { border-bottom: none; }
  .tm-edges .num { text-align: right; }
  .tm-edges a { color: var(--link); text-decoration: none; }
  .tm-edges a:hover { text-decoration: underline; }
  .best b { font-variant-numeric: tabular-nums; }
  .bk { color: var(--muted-2); font-size: 0.78rem; }

  @media (max-width: 720px) {
    .tm-hero { padding: 1.2rem 1.1rem; }
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>
