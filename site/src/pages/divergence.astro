---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Tooltip from "../components/Tooltip.astro";
import LocalTime from "../components/LocalTime.astro";
import {
  loadFixtures,
  loadPredictions,
  topDivergences,
  selectionLabel,
  signedPct,
  pct1,
} from "../lib/data";

const { matches } = loadFixtures();
const { predictions, generated_at } = loadPredictions();
const rows = topDivergences(predictions, matches);

const pct = (n: number) => `${pct1(n)}%`;

// Markets present, for the filter chips.
const markets = [...new Set(rows.map((r) => r.market))];

// Headline stats: how many disagreements lean each way, and the single biggest.
const valueCount = rows.filter((r) => r.delta > 0).length;
const fadeCount = rows.filter((r) => r.delta < 0).length;
const biggest = rows[0];
const updated = generated_at ? generated_at.slice(0, 16).replace("T", " ") : null;
---
<Base title="Model vs market — where we disagree | Soccer 26">
  <PageHero eyebrow="Model vs market" title="Where we disagree" tint="violet">
    <p class="ph-sub">
      Every priced match, ranked by how far the model's probability sits from the
      <Tooltip term="de-vigged" def="Bookmaker odds carry a margin (the vig). De-vigging rescales a market's implied probabilities to sum to 1, giving the market's true fair price. We use the power method." /> market price. A <b class="up">positive Δ</b> means the model rates
      the outcome <em>more</em> likely than the market (the value direction); a
      <b class="down">negative Δ</b> means the market rates it higher — often a sign the
      model is missing something, not the other way round. These are the model's gaps
      <em>after</em> per-confederation anchoring (which already removes the bulk of the old
      cross-confederation skew); our published call then <em>blends</em> each match toward
      the market, so the edges we actually bet are smaller still. This is a transparency
      view, not a bet list: large gaps are usually model blind spots, occasionally value.
    </p>
  </PageHero>

  {rows.length === 0 ? (
    <div class="panel" style="margin-top:1.2rem;">
      <p class="subtle" style="margin:0">
        No priced markets yet. Run <code>python model/fetch_odds.py --markets h2h,totals</code>
        then <code>python model/predict.py</code> to populate divergences.
      </p>
    </div>
  ) : (
    <>
      <div class="panel dv-stats" aria-label="Divergence summary">
        <div class="dv-stat">
          <span class="dv-val">{rows.length}</span>
          <span class="dv-lab">priced markets</span>
        </div>
        <div class="dv-stat">
          <span class="dv-val up">{valueCount}</span>
          <span class="dv-lab">model &gt; market</span>
        </div>
        <div class="dv-stat">
          <span class="dv-val down">{fadeCount}</span>
          <span class="dv-lab">market &gt; model</span>
        </div>
        {biggest && (
          <div class="dv-stat dv-big">
            <span class="dv-val">{signedPct(biggest.delta * 100)}</span>
            <span class="dv-lab">biggest gap · {biggest.home} v {biggest.away}</span>
          </div>
        )}
      </div>

      <div class="dv-controls" role="group" aria-label="Filter divergences">
        <div class="filters">
          <button class="chip is-on" data-dir="ALL" aria-pressed="true">All</button>
          <button class="chip" data-dir="up" aria-pressed="false">Model &gt; market</button>
          <button class="chip" data-dir="down" aria-pressed="false">Market &gt; model</button>
        </div>
        <div class="filters">
          <button class="chip chip-mkt is-on" data-market="ALL" aria-pressed="true">All markets</button>
          {markets.map((m) => (
            <button class="chip chip-mkt" data-market={m} aria-pressed="false">{m.replace(/_/g, " ")}</button>
          ))}
        </div>
      </div>

      <p id="dv-status" class="meta" aria-live="polite" style="margin:0.7rem 0 0;">
        {rows.length} markets shown{updated && ` · updated ${updated}`}
      </p>

      <div class="table-wrap" style="margin-top:0.9rem;">
        <table id="dv-table" class="table--cards">
          <thead>
            <tr>
              <th>Match</th>
              <th>Closest call</th>
              <th class="num">Model</th>
              <th class="num">Market</th>
              <th class="num">Δ</th>
              <th>Kickoff</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r) => {
              const dir = r.delta >= 0 ? "up" : "down";
              return (
              <tr data-dir={dir} data-market={r.market} data-absdelta={Math.abs(r.delta)} data-kickoff={r.kickoff ?? "9999"}>
                <td>
                  <a href={`/matches/${r.match_id}`}>{r.home} vs {r.away}</a>
                  <div class="meta mkt">{r.market.replace(/_/g, " ")}{r.group ? ` · Group ${r.group}` : ""}</div>
                </td>
                <td data-label="Closest call">{selectionLabel(r.selection, r.home, r.away)}</td>
                <td class="num" data-label="Model">{pct(r.model_prob * 100)}</td>
                <td class="num" data-label="Market">{pct(r.fair_prob * 100)}</td>
                <td class="num" data-label="Δ">
                  <span class={`badge dv-delta ${dir}`}>{signedPct(r.delta * 100)}</span>
                </td>
                <td class="meta" data-label="Kickoff"><LocalTime iso={r.kickoff} fmt="datetime" /></td>
              </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </>
  )}
</Base>

<script is:inline>
  // Client-side filter (direction + market) over already-rendered rows, kept in
  // the server's |Δ|-descending order — no re-sort needed.
  const table = document.getElementById("dv-table");
  if (table) {
    const tbody = table.querySelector("tbody");
    const rows = Array.from(tbody.querySelectorAll("tr"));
    const status = document.getElementById("dv-status");
    let dir = "ALL";
    let market = "ALL";

    function apply() {
      let shown = 0;
      rows.forEach((r) => {
        const ok = (dir === "ALL" || r.dataset.dir === dir) &&
                   (market === "ALL" || r.dataset.market === market);
        r.style.display = ok ? "" : "none";
        if (ok) shown++;
      });
      if (status) status.textContent = `${shown} market${shown === 1 ? "" : "s"} shown`;
    }

    function wire(selector, onPick) {
      const group = Array.from(document.querySelectorAll(selector));
      group.forEach((c) =>
        c.addEventListener("click", () => {
          group.forEach((x) => { x.classList.remove("is-on"); x.setAttribute("aria-pressed", "false"); });
          c.classList.add("is-on");
          c.setAttribute("aria-pressed", "true");
          onPick(c);
          apply();
        }),
      );
    }
    wire(".chip:not(.chip-mkt)", (c) => { dir = c.dataset.dir; });
    wire(".chip-mkt", (c) => { market = c.dataset.market; });
  }
</script>

<style>
  .ph-sub { margin: 0.55rem 0 0; max-width: 70ch; font-size: 0.92rem; line-height: 1.65; color: var(--muted); }
  .ph-sub em { color: var(--fg); font-style: normal; font-weight: 600; }
  .ph-sub .up { color: var(--accent); }
  .ph-sub .down { color: var(--warn); }

  .dv-stats { margin-top: 1.1rem; display: flex; flex-wrap: wrap; gap: 1rem 2.4rem; }
  .dv-stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .dv-val {
    font-family: var(--font-mono); font-weight: 600; font-size: 1.45rem; color: var(--fg);
    font-variant-numeric: tabular-nums slashed-zero; letter-spacing: -0.02em;
  }
  .dv-val.up { color: var(--accent); }
  .dv-val.down { color: var(--warn); }
  .dv-lab {
    font-family: var(--font-mono); font-size: 0.7rem; color: var(--muted-2);
    text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600;
  }
  .dv-big { min-width: 0; }
  .dv-big .dv-lab { text-transform: none; letter-spacing: 0; font-family: inherit; }

  .dv-controls {
    display: flex; flex-wrap: wrap; gap: 0.7rem 1.4rem;
    align-items: center; margin-top: 1.1rem;
  }
  .filters { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .chip {
    font: inherit; cursor: pointer;
    display: inline-flex; align-items: center; min-height: 44px;
    padding: 0.3rem 0.85rem; border-radius: var(--radius-sm);
    border: 1px solid var(--border-strong);
    background: var(--surface-2); color: var(--muted);
    font-size: 0.8rem; font-weight: 600;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
  }
  .chip:hover { color: var(--fg); }
  .chip.is-on {
    color: #060a1a; border-color: transparent;
    background: linear-gradient(140deg, var(--accent), var(--accent-2));
  }
  .mkt { font-size: 0.76rem; margin-top: 0.15rem; text-transform: capitalize; }

  .dv-delta { font-variant-numeric: tabular-nums; }
  .dv-delta.up { color: var(--accent); border: 1px solid var(--accent-line); background: var(--accent-soft); }
  .dv-delta.down { color: var(--warn); border: 1px solid rgba(255,181,36,0.4); background: var(--warn-soft); }
</style>
