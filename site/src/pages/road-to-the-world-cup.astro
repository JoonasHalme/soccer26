---
import Base from "../layouts/Base.astro";
import TeamFlag from "../components/TeamFlag.astro";
import { loadForm, teamSlug, flagCode } from "../lib/data";

const form = loadForm();
const feed = form.recent ?? [];
const rec = form.record ?? { correct: 0, total: 0 };
const pct = rec.total ? Math.round((100 * rec.correct) / rec.total) : 0;

// Team table: who's arriving in form. Sort by points from the last 5 (W=3, D=1).
const fp = (s: string) => s.split("").reduce((a, c) => a + (c === "W" ? 3 : c === "D" ? 1 : 0), 0);
const teamRows = Object.entries(form.teams)
  .map(([team, tf]) => ({ team, tf, fp: fp(tf.form) }))
  .sort((a, b) => b.fp - a.fp || (b.tf.record?.correct ?? 0) - (a.tf.record?.correct ?? 0));

const isWC = (name: string) => name in form.teams;
const teamsInFeed = new Set(feed.flatMap((m) => [m.home, m.away]).filter((n) => n in form.teams)).size;
const allFriendly = feed.length > 0 && feed.every((m) => m.friendly);
const fmtDate = (iso: string) =>
  new Date(iso + "T00:00:00Z").toLocaleDateString("en-GB", { day: "numeric", month: "short", timeZone: "UTC" });
const pct0 = (x: number) => Math.round(x * 100);
const pickName = (m: (typeof feed)[number]) =>
  m.model.pick === "H" ? m.home : m.model.pick === "A" ? m.away : "Draw";

// Normalised name → {name, slug} lookup so the client-side live widget can match
// ESPN's team spellings to our 48 (e.g. "United States" → USA). Aliases cover the
// known divergences; everything else matches on accent-stripped alphanumerics.
const norm = (s: string) =>
  s.toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "").replace(/\b(and|the)\b/g, "").replace(/[^a-z0-9]/g, "");
const ALIASES: Record<string, string[]> = {
  "USA": ["United States"],
  "South Korea": ["Korea Republic"],
  "Iran": ["IR Iran"],
  "Ivory Coast": ["Cote d'Ivoire", "Côte d'Ivoire"],
  "DR Congo": ["Congo DR", "Congo DR (Kinshasa)"],
  "Cape Verde": ["Cabo Verde"],
  "Bosnia & Herzegovina": ["Bosnia and Herzegovina"],
};
const wcLookup: Record<string, { name: string; slug: string; cc: string | null }> = {};
for (const team of Object.keys(form.teams)) {
  const entry = { name: team, slug: teamSlug(team), cc: flagCode(team) };
  wcLookup[norm(team)] = entry;
  for (const a of ALIASES[team] ?? []) wcLookup[norm(a)] = entry;
}

const title = "Road to the World Cup — the model's pre-match calls on every warm-up | Soccer 26";
const description =
  "Every pre-tournament warm-up and run-in result for the 48 World Cup 2026 teams, each with the model's own pre-match call (walk-forward, no hindsight) — hits and misses shown in full as an honest track record going into kickoff.";
---
<Base title={title} description={description}>
  <section class="rd-hero">
    <p class="eyebrow">Pre-tournament · Full transparency</p>
    <h1>Road to the World Cup</h1>
    <p class="subtle rd-lede">
      The warm-ups and run-in for all 48 teams — and, on every game, <b>what our model
      predicted before kickoff</b> (computed from ratings as they stood <i>before</i> the
      match — no hindsight). We show the misses too: this is the model's honest track
      record walking into the tournament, not a highlight reel.
    </p>
    <div class="rd-stats">
      <div class="rd-stat accent">
        <span class="rd-n">{rec.correct}/{rec.total}</span>
        <span class="rd-l">pre-match calls correct</span>
      </div>
      <div class="rd-stat">
        <span class="rd-n">{pct}%</span>
        <span class="rd-l">hit rate on the run-in</span>
      </div>
      <div class="rd-stat">
        <span class="rd-n">{teamsInFeed}</span>
        <span class="rd-l">World Cup teams in action</span>
      </div>
    </div>
    <p class="rd-caveat">
      {allFriendly ? "These are all " : "Most of these are "}<b>warm-up friendlies</b> — rotated XIs, experiments, little at
      stake — so even a sharp model is often wrong, and the market itself moves little on
      them. That's exactly why the model counts them at <b>half weight</b>. Read the hit
      rate as honesty, not a promise. <a href="/methodology#ratings">How ratings work →</a>
    </p>
  </section>

  <!-- Live + upcoming warm-ups (client-side, ESPN scoreboard). Hidden until populated. -->
  <section class="rd-section" id="live-warmups" hidden>
    <div class="section-head"><h2>Tonight's warm-ups</h2><span class="count lw-count">live &amp; upcoming</span><span class="rule"></span></div>
    <div class="table-wrap"><ul id="lw-list" class="lw-list"></ul></div>
    <p class="subtle lw-foot">
      Live scores fetched in your browser from <a href="https://www.espn.com/soccer/scoreboard/_/league/fifa.friendly" rel="noopener noreferrer" target="_blank">ESPN</a>;
      finished games also flow into the permanent record below.
    </p>
  </section>

  <section class="rd-section">
    <div class="section-head"><h2>Every call on the run-in</h2><span class="count">since {form.since ? fmtDate(form.since) : "May"}</span><span class="rule"></span></div>
    <div class="table-wrap">
      <table class="rd-feed table--cards">
        <thead>
          <tr><th>Date</th><th>Match</th><th>Result</th><th>Model's pre-match call</th></tr>
        </thead>
        <tbody>
          {feed.map((m) => (
            <tr>
              <td class="meta" data-label="Date">{fmtDate(m.date)}</td>
              <td data-label="Match">
                <span class="rd-fix">
                  <span class="rd-side">
                    <TeamFlag team={m.home} size={18} />
                    {isWC(m.home) ? <a href={`/team/${teamSlug(m.home)}`}>{m.home}</a> : <span>{m.home}</span>}
                  </span>
                  <span class="rd-v">v</span>
                  <span class="rd-side">
                    <TeamFlag team={m.away} size={18} />
                    {isWC(m.away) ? <a href={`/team/${teamSlug(m.away)}`}>{m.away}</a> : <span>{m.away}</span>}
                  </span>
                  {m.friendly && <span class="rd-half" title="Exhibition — counted at half weight in the model">×½</span>}
                </span>
              </td>
              <td class="num" data-label="Result"><b class="rd-score">{m.hs}–{m.as}</b></td>
              <td data-label="Model's pre-match call">
                <span class={`rd-call ${m.model.correct ? "hit" : "miss"}`}>
                  <span class="rd-mark">{m.model.correct ? "✓" : "✗"}</span>
                  {pickName(m)}
                  <span class="rd-p" title={`Model gave the actual result ${pct0(m.model.p_actual)}% (home ${pct0(m.model.ph)}% · draw ${pct0(m.model.pd)}% · away ${pct0(m.model.pa)}%)`}>
                    {pct0(m.model.p_actual)}%
                  </span>
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="subtle rd-foot">
      <b>✓/✗</b> is whether the model's most-likely pre-match outcome matched the result;
      the <b>%</b> is the probability it gave the <i>actual</i> result (so a confident miss
      reads low). Pure transparency — no cherry-picking.
    </p>
  </section>

  <section class="rd-section">
    <div class="section-head"><h2>How every team is arriving</h2><span class="count">last 5, in form first</span><span class="rule"></span></div>
    <div class="table-wrap">
      <table class="rd-teams table--cards">
        <thead>
          <tr><th>Team</th><th>Form</th><th class="num">Model record</th><th>Last result</th></tr>
        </thead>
        <tbody>
          {teamRows.map(({ team, tf }) => {
            const last = tf.matches[0];
            return (
              <tr>
                <td data-label="Team">
                  <a class="rd-team" href={`/team/${teamSlug(team)}`}><TeamFlag team={team} size={20} />{team}</a>
                </td>
                <td data-label="Form">
                  <span class="rd-chips">
                    {tf.form.split("").map((r) => <span class={`fchip f-${r}`}>{r}</span>)}
                  </span>
                </td>
                <td class="num" data-label="Model record">
                  {tf.record ? <span class="rd-rec">{tf.record.correct}/{tf.record.total}</span> : "—"}
                </td>
                <td class="meta" data-label="Last result">
                  {last ? (
                    <span>{last.res} {last.home ? "v" : "@"} {last.opp} <b>{last.gf}–{last.ga}</b></span>
                  ) : "—"}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
</Base>

<script define:vars={{ wcLookup }}>
  // Live + upcoming WC-team warm-ups, fetched client-side from ESPN's free, no-key
  // friendly scoreboard. Degrades silently: on any failure or no relevant games the
  // section stays hidden. Polls while a game is live; pauses when the tab is hidden.
  (() => {
    const sec = document.getElementById("live-warmups");
    const list = document.getElementById("lw-list");
    if (!sec || !list) return;
    const ENDPOINT = "https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.friendly/scoreboard?dates=";
    const norm = (s) => (s || "").toLowerCase().normalize("NFD").replace(/[̀-ͯ]/g, "")
      .replace(/\b(and|the)\b/g, "").replace(/[^a-z0-9]/g, "");
    const esc = (s) => (s || "").replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]));
    const ymd = (d) => `${d.getFullYear()}${String(d.getMonth() + 1).padStart(2, "0")}${String(d.getDate()).padStart(2, "0")}`;
    const windowDates = () => {
      const out = [], now = new Date();
      // yesterday..+3. "Yesterday" matters because ESPN files a game under its UTC
      // date: a 22:00Z kickoff is tonight in Europe but ESPN dates it the prior day,
      // so without it a game live right now in a later timezone would be missed.
      for (let i = -1; i <= 3; i++) { const d = new Date(now); d.setDate(now.getDate() + i); out.push(ymd(d)); }
      return out;
    };
    const flagImg = (cc) => cc
      ? `<img class="lw-flag" src="https://flagcdn.com/w20/${cc}.png" srcset="https://flagcdn.com/w40/${cc}.png 2x" width="20" height="15" alt="" loading="lazy" decoding="async">`
      : "";
    const teamCell = (t) => {
      const flag = t.wc ? flagImg(t.wc.cc) : "";
      const nm = t.wc
        ? `<a href="/team/${t.wc.slug}">${esc(t.wc.name)}</a>`
        : `<span>${esc(t.name)}</span>`;
      return `<span class="lw-team">${flag}${nm}</span>`;
    };
    function rowHtml(r) {
      const live = r.state === "in", post = r.state === "post";
      const d = new Date(r.date);
      const time = d.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
      const today = new Date().toDateString() === d.toDateString();
      const koLabel = today ? time : `${d.toLocaleDateString([], { weekday: "short" })} ${time}`;
      const mid = (live || post)
        ? `<span class="lw-score">${esc(String(r.hs))}–${esc(String(r.as))}</span>`
        : `<span class="lw-vs">v</span>`;
      const status = live
        ? `<span class="lw-tag lw-live"><span class="lw-dot"></span>${esc(r.clock || "LIVE")}</span>`
        : post ? `<span class="lw-tag lw-ft">FT</span>`
        : `<span class="lw-tag lw-ko">${esc(koLabel)}</span>`;
      return `<li class="lw-row${live ? " is-live" : ""}">${teamCell(r.home)}${mid}${teamCell(r.away)}${status}</li>`;
    }
    async function load() {
      let events = [];
      for (const d of windowDates()) {
        try {
          const res = await fetch(ENDPOINT + d, { mode: "cors" });
          if (!res.ok) continue;
          const json = await res.json();
          if (Array.isArray(json.events)) events = events.concat(json.events);
        } catch (_) { /* ignore a single bad date */ }
      }
      const rows = [], seen = new Set();
      for (const e of events) {
        if (seen.has(e.id)) continue;
        seen.add(e.id);
        const comp = e.competitions && e.competitions[0];
        const cs = (comp && comp.competitors) || [];
        const home = cs.find((c) => c.homeAway === "home");
        const away = cs.find((c) => c.homeAway === "away");
        if (!home || !away) continue;
        const hw = wcLookup[norm(home.team.displayName || home.team.name)];
        const aw = wcLookup[norm(away.team.displayName || away.team.name)];
        if (!hw && !aw) continue; // only friendlies involving a WC team
        const st = (e.status && e.status.type) || {};
        // drop stale finals (yesterday's are recent; older ones live in the feed below)
        if (st.state === "post" && (Date.now() - new Date(e.date).getTime()) / 3.6e6 > 20) continue;
        rows.push({
          date: e.date, state: st.state, clock: (e.status && e.status.displayClock) || st.shortDetail,
          hs: home.score, as: away.score,
          home: { name: home.team.displayName, wc: hw }, away: { name: away.team.displayName, wc: aw },
        });
      }
      if (!rows.length) { sec.hidden = true; return false; }
      const rank = (s) => (s === "in" ? 0 : s === "pre" ? 1 : 2);
      rows.sort((a, b) => rank(a.state) - rank(b.state) || new Date(a.date) - new Date(b.date));
      list.innerHTML = rows.slice(0, 10).map(rowHtml).join("");
      sec.hidden = false;
      return rows.some((r) => r.state === "in");
    }
    let timer;
    async function tick() {
      let anyLive = false;
      try { anyLive = await load(); } catch (_) { /* keep section as-is */ }
      clearTimeout(timer);
      timer = setTimeout(tick, anyLive ? 60000 : 300000); // 1 min while live, else 5 min
    }
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) clearTimeout(timer); else tick();
    });
    if (!document.hidden) tick();
  })();
</script>

<style>
  .rd-hero {
    border-radius: var(--radius-lg); border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    padding: var(--s-6) var(--s-5); box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  }
  .rd-hero h1 { margin: 0.3rem 0 0; }
  .rd-lede { max-width: 70ch; margin: 0.6rem 0 0; line-height: 1.6; }
  .rd-lede b { color: var(--fg); }

  .rd-stats { display: flex; gap: 1.6rem; flex-wrap: wrap; margin: 1.3rem 0 0; }
  .rd-stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .rd-n { font-family: var(--font-mono); font-weight: 700; font-size: 1.7rem; color: var(--fg); font-variant-numeric: tabular-nums slashed-zero; line-height: 1; }
  .rd-stat.accent .rd-n { color: var(--accent); }
  .rd-l { font-size: 0.74rem; color: var(--muted-2); text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
  .rd-caveat { max-width: 72ch; margin: 1.2rem 0 0; font-size: 0.84rem; color: var(--muted); line-height: 1.6; }
  .rd-caveat b { color: var(--fg); font-weight: 600; }
  .rd-caveat a, .rd-foot a { color: var(--link); text-decoration: none; }
  .rd-caveat a:hover { text-decoration: underline; }

  .rd-section { margin-top: 2.1rem; }
  .table-wrap { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1px solid var(--border-soft); border-radius: var(--radius-sm); }
  .rd-feed, .rd-teams { border-collapse: collapse; width: 100%; font-size: 0.9rem; }
  .rd-feed th, .rd-feed td, .rd-teams th, .rd-teams td { text-align: left; padding: 0.55rem 0.8rem; border-bottom: 1px solid var(--border-soft); white-space: nowrap; }
  .rd-feed thead th, .rd-teams thead th { color: var(--muted-2); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .rd-feed tbody tr:last-child td, .rd-teams tbody tr:last-child td { border-bottom: none; }
  .rd-feed .num, .rd-teams .num { text-align: right; }
  .rd-feed .meta, .rd-teams .meta { color: var(--muted); }
  .rd-feed a, .rd-teams a { color: var(--link); text-decoration: none; }
  .rd-feed a:hover, .rd-teams a:hover { text-decoration: underline; }

  .rd-fix { display: inline-flex; align-items: center; gap: 0.5rem; }
  .rd-side { display: inline-flex; align-items: center; gap: 0.35rem; }
  .rd-v { color: var(--muted-2); font-size: 0.78rem; }
  .rd-score { font-variant-numeric: tabular-nums; }
  .rd-half { font-family: var(--font-mono); font-size: 0.66rem; color: var(--muted); background: var(--surface-2); border: 1px solid var(--border); border-radius: 4px; padding: 0.01rem 0.28rem; cursor: help; }

  .rd-call { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; border-radius: 6px; padding: 0.12rem 0.5rem; }
  .rd-call.hit  { color: var(--accent); background: var(--accent-soft); border: 1px solid var(--accent-line); }
  .rd-call.miss { color: var(--bad); background: var(--bad-soft); border: 1px solid var(--bad-line); }
  .rd-mark { font-family: var(--font-mono); font-weight: 700; }
  .rd-p { font-family: var(--font-mono); font-size: 0.74rem; color: var(--muted-2); cursor: help; }

  .rd-team { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--fg); font-weight: 500; }
  .rd-chips { display: inline-flex; gap: 0.25rem; }
  .fchip { width: 1.3rem; height: 1.3rem; border-radius: 5px; display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-mono); font-weight: 700; font-size: 0.72rem; }
  .f-W { background: var(--accent); color: var(--accent-ink); }
  .f-D { background: var(--surface-2); color: var(--muted); border: 1px solid var(--border); }
  .f-L { background: var(--bad); color: var(--bad-ink); }
  .rd-rec { font-family: var(--font-mono); font-variant-numeric: tabular-nums; color: var(--fg); }

  .rd-foot { margin: 0.8rem 0 0; font-size: 0.8rem; line-height: 1.55; }
  .rd-foot b { color: var(--fg); }

  .lw-count { color: var(--accent); }   /* the rest of .lw-* lives in the global block (JS-injected) */

  @media (max-width: 720px) {
    .rd-hero { padding: 1.3rem 1.2rem; }
    .rd-stats { gap: 1.1rem; }
  }
</style>

<style is:global>
  /* "Tonight's warm-ups" rows are injected by JS, so their styles must be global
     (scoped styles only match server-rendered elements). Namespaced under
     #live-warmups so nothing leaks. */
  #live-warmups .lw-list { list-style: none; margin: 0; padding: 0; }
  #live-warmups .lw-row {
    display: flex; align-items: center; gap: 0.55rem;
    padding: 0.6rem 0.85rem; border-top: 1px solid var(--border-soft);
  }
  #live-warmups .lw-row:first-child { border-top: none; }
  #live-warmups .lw-row.is-live { box-shadow: inset 2px 0 0 var(--bad); }
  #live-warmups .lw-team { display: inline-flex; align-items: center; gap: 0.4rem; min-width: 0; color: var(--fg); white-space: nowrap; }
  #live-warmups .lw-team a { color: var(--fg); text-decoration: none; }
  #live-warmups .lw-team a:hover { color: var(--accent); text-decoration: underline; }
  #live-warmups .lw-flag { border-radius: 2px; box-shadow: 0 0 0 1px var(--border-soft); flex: none; vertical-align: middle; }
  #live-warmups .lw-vs { color: var(--muted-2); font-size: 0.78rem; padding: 0 0.1rem; }
  #live-warmups .lw-score { font-family: var(--font-mono); font-variant-numeric: tabular-nums slashed-zero; font-weight: 700; color: var(--fg); padding: 0 0.15rem; }
  #live-warmups .lw-tag {
    margin-left: auto; flex: none; font-family: var(--font-mono); font-size: 0.72rem;
    white-space: nowrap; padding: 0.1rem 0.5rem; border-radius: 999px; border: 1px solid var(--border-soft);
  }
  #live-warmups .lw-ko { color: var(--muted-2); }
  #live-warmups .lw-ft { color: var(--muted); }
  #live-warmups .lw-live {
    display: inline-flex; align-items: center; gap: 0.3rem;
    color: var(--bad); font-weight: 700; background: var(--bad-soft); border-color: var(--bad-line);
  }
  #live-warmups .lw-dot { width: 0.45rem; height: 0.45rem; border-radius: 999px; background: var(--bad); animation: lw-breathe 1.8s ease-in-out infinite; }
  @keyframes lw-breathe { 50% { opacity: 0.4; } }
  #live-warmups .lw-foot { margin: 0.8rem 0 0; font-size: 0.78rem; color: var(--muted); }
  #live-warmups .lw-foot a { color: var(--link); text-decoration: none; }
  #live-warmups .lw-foot a:hover { text-decoration: underline; }
</style>
