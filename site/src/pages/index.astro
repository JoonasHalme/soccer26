---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import MatchCard from "../components/MatchCard.astro";
import NewsItem from "../components/NewsItem.astro";
import KickoffCountdown from "../components/KickoffCountdown.astro";
import LocalTime from "../components/LocalTime.astro";
import Newsletter from "../components/Newsletter.astro";
import { loadFixtures, loadPredictions, loadNews, nextMatchday, selectionLabel, selectionShort, pct1, oddsMovedSincePredictions, oddsAsOf } from "../lib/data";

const fixtures = loadFixtures();
const { predictions, generated_at } = loadPredictions();
const news = loadNews();
const latestNews = news.items.slice(0, 8);

const analyses = await getCollection("matches");
const analyzedIds = new Set(analyses.map((a) => a.data.match_id));

const predById = new Map(predictions.map((p) => [p.match_id, p]));

const now = new Date();
const scheduled = fixtures.matches
  .filter((m) => m.status === "SCHEDULED" && m.kickoff)
  .sort((a, b) => (a.kickoff ?? "").localeCompare(b.kickoff ?? ""));

const upcoming = scheduled
  .filter((m) => new Date(m.kickoff!) > now)
  .slice(0, 6);

const edgeCount = predictions.reduce((s, p) => s + (p.edges?.length ?? 0), 0);

// Date-aware "what to look at right now" module.
const matchday = nextMatchday(fixtures.matches, now);
const topEdgeFor = (id: string) => {
  const es = predById.get(id)?.edges ?? [];
  return es.length ? es.reduce((a, b) => (b.edge_pct > a.edge_pct ? b : a)) : null;
};

// Teams with a tagged injury story in the feed, to badge matchday rows where a
// fitness doubt touches either side. `is_injury_related` + team tags already exist.
const injuryTeams = new Set(
  news.items.filter((n) => n.is_injury_related).flatMap((n) => n.teams),
);
const injuryFor = (m: { home: string; away: string }) =>
  [m.home, m.away].filter((t) => injuryTeams.has(t));
---
<Base title="Dashboard — Soccer 26">
  <section class="hero">
    <p class="eyebrow">FIFA World Cup 2026 · Transparent model</p>
    <h1 class="hero-title">Every probability,<br />shown and <em>graded in public</em>.</h1>
    <p class="hero-sub">
      One Elo + Poisson model, calibrated on thousands of historical internationals and
      open to inspection. It flags value only where it genuinely disagrees with the
      de-vigged market — and every bet is logged and scored against the closing line.
      Analysis, not tips.
    </p>
    <div class="hero-chips">
      <span class="hero-chip"><b>{fixtures.matches.length}</b> fixtures</span>
      <span class="hero-chip"><b>{predictions.length}</b> modelled</span>
      <span class="hero-chip accent"><b>{edgeCount}</b> value edges</span>
      <a class="hero-chip link" href="/calibration">How it's calibrated →</a>
    </div>
  </section>

  {matchday.matches.length > 0 && (
    <section class="matchday" aria-label="Next matchday">
      <div class="md-head">
        <span class={`md-eyebrow ${matchday.isToday ? "is-today" : ""}`}>
          {matchday.isToday ? "● Today" : "Next matchday"}
        </span>
        <h2 class="md-title">{matchday.label}</h2>
        <span class="md-count">{matchday.matches.length} match{matchday.matches.length === 1 ? "" : "es"}</span>
      </div>
      <div class="md-list">
        {matchday.matches.map((m) => {
          const e = topEdgeFor(m.id);
          const live = m.status === "LIVE";
          const injured = injuryFor(m);
          return (
            <a class="md-row" href={`/matches/${m.id}`} data-match-id={m.id}>
              <span class="md-time">
                <LocalTime class="md-clock" iso={m.kickoff} fmt="time" />
                <KickoffCountdown kickoff={m.kickoff} status={m.status} />
              </span>
              <span class="md-teams">{m.home} <span class="md-v">v</span> {m.away}</span>
              <span class="md-tail">
                {injured.length > 0 && (
                  <span class="md-injury" title={`Injury news touching ${injured.join(" & ")} — see the match page`}>
                    <span aria-hidden="true">✚</span> injury news
                    <span class="sr-only"> for {injured.join(" and ")}</span>
                  </span>
                )}
                {e && (
                  <span class="badge badge-edge" title={selectionLabel(e.selection, m.home, m.away)}>
                    +{pct1(e.edge_pct)}% {selectionShort(e.selection)}
                  </span>
                )}
                <span class={`pill ${live ? "live" : ""}`}>{live ? "LIVE" : (m.group ? `Group ${m.group}` : m.stage)}</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <section style="margin-top: 2.25rem;">
    <div class="section-head">
      <h2>Next up</h2>
      <span class="count">{upcoming.length} match{upcoming.length === 1 ? "" : "es"}</span>
      <span class="rule"></span>
      <a href="/matches" class="see-all">All matches →</a>
    </div>
    {upcoming.length === 0 ? (
      <div class="panel"><p class="subtle" style="margin:0">No scheduled matches right now — the schedule fills in ahead of kick-off (11 June).</p></div>
    ) : (
      <div class="cards-grid">
        {upcoming.map((m) => (
          <MatchCard match={m} pred={predById.get(m.id)} analyzed={analyzedIds.has(m.id)} />
        ))}
      </div>
    )}
  </section>

  {latestNews.length > 0 && (
    <section style="margin-top: 2.25rem;">
      <div class="section-head">
        <h2>Latest team news</h2>
        <span class="count">RSS · injuries, squads, lineups</span>
        <span class="rule"></span>
        <a href="/matches" class="see-all">Per-match news →</a>
      </div>
      <div class="news-grid">
        {latestNews.map((item) => <NewsItem item={item} />)}
      </div>
    </section>
  )}

  <section style="margin-top: 2.25rem;">
    <Newsletter />
  </section>

  <p class="meta freshness" style="margin-top: 2rem;">
    {generated_at ? (
      <>
        Predictions generated <LocalTime iso={generated_at} fmt="datetime" />
        {oddsAsOf(fixtures.matches) && (
          oddsMovedSincePredictions(generated_at, fixtures.matches) ? (
            <span class="fresh-badge stale" title="The market has moved since the model last ran — re-run python model/predict.py">odds moved since — refresh</span>
          ) : (
            <span class="fresh-badge ok" title="No book quotes a price newer than this prediction set">✓ in sync with latest odds</span>
          )
        )}
      </>
    ) : "Predictions update ahead of kick-off."}
  </p>
</Base>

<script is:inline>
  // Fill the kickoff countdowns and keep them ticking. No-JS fallback is the
  // static kickoff time already rendered server-side.
  (function () {
    const els = Array.from(document.querySelectorAll(".countdown[data-kickoff]"));
    if (!els.length) return;
    function rel(ko, status) {
      const t = new Date(ko).getTime();
      if (Number.isNaN(t)) return { text: "", live: false, soon: false };
      const diff = t - Date.now();
      if (status === "FINISHED") return { text: "FT", live: false, soon: false };
      if (status === "LIVE" || (diff < 0 && diff > -3 * 3600 * 1000))
        return { text: "LIVE", live: true, soon: false };
      if (diff <= 0) return { text: "done", live: false, soon: false };
      const mins = Math.floor(diff / 60000);
      const d = Math.floor(mins / 1440);
      const h = Math.floor((mins % 1440) / 60);
      const m = mins % 60;
      let text;
      if (d > 0) text = `in ${d}d ${h}h`;
      else if (h > 0) text = `in ${h}h ${m}m`;
      else text = `in ${m}m`;
      return { text, live: false, soon: diff < 6 * 3600 * 1000 };
    }
    function tick() {
      for (const el of els) {
        const r = rel(el.dataset.kickoff, el.dataset.status);
        if (!r.text) continue;
        el.textContent = r.text;
        if (r.live) el.setAttribute("data-live", "1"); else el.removeAttribute("data-live");
        if (r.soon) el.setAttribute("data-soon", "1"); else el.removeAttribute("data-soon");
      }
    }
    tick();
    setInterval(tick, 30000);
  })();

  // Live matchday mode: poll the lightweight /data/live.json (emitted by
  // model/publish_live.py on matchdays) and patch in LIVE/FT scores without a
  // rebuild. Fully no-op when the file is absent or has no scored matches (the
  // normal pre-tournament state), so it never disturbs the static page.
  (function () {
    var rows = Array.from(document.querySelectorAll(".md-row[data-match-id]"));
    if (!rows.length) return;
    function paint(data) {
      var m = (data && data.matches) || {};
      var anyLive = false;
      rows.forEach(function (row) {
        var s = m[row.getAttribute("data-match-id")];
        var pill = row.querySelector(".pill");
        if (!s || !pill) return;
        var live = s.status === "LIVE";
        pill.textContent = (live ? "LIVE " : "FT ") + s.home + "–" + s.away;
        pill.classList.toggle("live", live);
        row.setAttribute("data-result", "1");
        if (live) anyLive = true;
      });
      return anyLive;
    }
    function poll() {
      fetch("/data/live.json")  // edge-cached ~30s via site/public/_headers
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (d) { if (d) paint(d); })
        .catch(function () {});
    }
    poll();
    setInterval(poll, 60000);
  })();
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--surface-2), var(--surface));
    padding: var(--s-6) var(--s-5);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
  }
  .hero-title {
    font-size: clamp(1.9rem, 4.4vw, 3rem);
    line-height: 1.05;
    margin: 0.6rem 0 0.7rem;
    letter-spacing: -0.035em;
    color: var(--fg);
    font-weight: 700;
  }
  .hero-title em { font-style: normal; color: var(--accent); }
  .hero-sub { max-width: 56ch; color: var(--muted); font-size: 1.02rem; margin: 0 0 1.25rem; }
  /* .hero-chip styles are global (Base.astro). */


  .freshness { display: inline-flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; }
  .fresh-badge {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.02em;
    padding: 0.08rem 0.5rem; border-radius: var(--radius-sm); white-space: nowrap;
  }
  .fresh-badge.ok { color: var(--accent); background: var(--accent-soft); border: 1px solid var(--accent-line); }
  .fresh-badge.stale { color: var(--warn); background: var(--warn-soft); border: 1px solid var(--warn-line); }

  /* Date-aware matchday band */
  .matchday {
    margin-top: 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--elev), transparent 120px), var(--surface);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }
  .md-head {
    display: flex; align-items: baseline; gap: 0.8rem;
    padding: 0.95rem 1.3rem 0.75rem;
    border-bottom: 1px solid var(--border-soft);
  }
  .md-eyebrow {
    text-transform: uppercase; letter-spacing: 0.14em;
    font-size: 0.72rem; font-weight: 700; color: var(--muted-2);
  }
  .md-eyebrow.is-today { color: var(--accent); }
  .md-title { margin: 0; font-size: 1.15rem; }
  .md-count { margin-left: auto; font-size: 0.8rem; color: var(--muted-2); font-weight: 600; }
  .md-list { display: flex; flex-direction: column; }
  .md-row {
    display: grid;
    grid-template-columns: minmax(120px, auto) 1fr auto;
    align-items: center; gap: 1rem;
    padding: 0.8rem 1.3rem;
    border-bottom: 1px solid var(--border-soft);
    color: var(--fg); text-decoration: none;
    transition: background 0.12s ease;
  }
  .md-row:last-child { border-bottom: none; }
  .md-row:hover { background: var(--elev); text-decoration: none; }
  .md-time { display: flex; flex-direction: column; line-height: 1.25; }
  .md-clock { font-family: var(--font-mono); font-weight: 600; font-size: 1.05rem; font-variant-numeric: tabular-nums slashed-zero; }
  .md-time .countdown { font-size: 0.76rem; }
  .md-teams { font-weight: 600; }
  .md-v { color: var(--muted-2); font-weight: 500; margin: 0 0.15rem; }
  .md-tail { display: inline-flex; align-items: center; gap: 0.5rem; justify-content: flex-end; }
  .md-injury {
    display: inline-flex; align-items: center; gap: 0.25rem;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.02em;
    color: var(--warn); border: 1px solid var(--warn-line);
    background: var(--warn-soft); border-radius: var(--radius-sm);
    padding: 0.12rem 0.5rem; white-space: nowrap;
  }
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }
  @media (max-width: 720px) {
    .md-row { grid-template-columns: auto 1fr; }
    .md-tail { grid-column: 1 / -1; justify-content: flex-start; }
  }

  .see-all { font-size: 0.85rem; font-weight: 600; white-space: nowrap; }

  .news-grid {
    display: grid; gap: 0.7rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }

  @media (max-width: 720px) {
    .hero { padding: 1.7rem 1.3rem; }
    .hero-title br { display: none; }
  }
</style>
