---
import "@fontsource-variable/inter";
import "@fontsource-variable/sora";
import "@fontsource-variable/jetbrains-mono";
import MobileNav from "../components/MobileNav.astro";
interface Props {
  title?: string;
  description?: string;
  /** Build-time OG card path (see src/pages/og/). Defaults to the site card. */
  ogImage?: string;
}
const {
  title = "Soccer 26",
  description = "A transparent, calibration-first World Cup 2026 forecasting model: win probabilities, value edges vs the de-vigged market, and a publicly-graded CLV track record. Analysis, not tips.",
  ogImage = "/og/default.png",
} = Astro.props;
const path = Astro.url.pathname;
// Absolute once a deploy domain is set as `site` in astro.config (SITE_URL); until
// then these resolve relative to the current origin. OG/canonical need a public
// absolute URL to work on social + for SEO — all upgrade automatically with `site`.
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
const canonicalUrl = Astro.site ? new URL(path, Astro.site).href : path;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
// Secondary routes live under a "More" dropdown so the top bar stays uncluttered.
const MORE_ROUTES = ["/divergence", "/predict", "/methodology"];
const moreActive = MORE_ROUTES.some((h) => isActive(h));
const year = new Date().getFullYear();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0c14" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" type="application/rss+xml" title="Soccer 26 — value edges & team news" href="/feed.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        /* Base surfaces — deep, slightly blue-violet night */
        --bg: #0a0c14;
        --bg-2: #0d1020;
        --surface: #12162a;
        --surface-2: #171c34;
        --surface-3: #1e2440;
        --elev: rgba(255, 255, 255, 0.04);
        /* Crisper, higher-contrast hairlines (was muddy low-contrast blue-grey) for
           the "engineered / ruled" feel of a sharp data UI. */
        --border: #303863;
        --border-soft: #20253e;
        --border-strong: #424c79;

        /* Text */
        /* Softer off-white (was near-pure #eef1fb, which glared on the dark canvas).
           Still ~12:1 on --bg, so contrast stays well above AA. */
        --fg: #cfd5e4;
        --muted: #939cba;
        --muted-2: #6b7498;

        /* Brand accents — pitch green + tournament magenta */
        /* Muted emerald — desaturated + a touch darker than the old neon #1fe07a,
           which read too bright/harsh. Still clearly the "positive/edge" green. */
        --accent: #2fb672;
        --accent-2: #209a5b;
        --accent-soft: rgba(47, 182, 114, 0.13);
        --accent-line: rgba(47, 182, 114, 0.40);
        --magenta: #ff3d8b;
        --magenta-soft: rgba(255, 61, 139, 0.14);
        --cyan: #3dd7ff;
        --cyan-soft: rgba(61, 215, 255, 0.14);

        /* Semantic */
        --warn: #ffb524;
        --warn-soft: rgba(255, 181, 36, 0.14);
        --bad: #ff5470;
        --bad-soft: rgba(255, 84, 112, 0.14);
        --good: var(--accent);
        --link: #6aa8ff;

        /* Sharp by request — crisp, engineered corners, not soft app rounding.
           Data containers ~6px, small elements 4px, hero 8px; status dots stay round. */
        --radius: 6px;
        --radius-sm: 4px;
        --radius-lg: 8px;
        /* Flatter, tighter elevation — depth via border + surface, not heavy blur
           (design-team direction: "calm authority, an instrument not an app"). */
        --shadow: 0 1px 0 rgba(0, 0, 0, 0.5);            /* hairline contact, not a glow */
        --shadow-md: 0 4px 12px -6px rgba(0, 0, 0, 0.6); /* floating layers only */
        --shadow-lg: 0 12px 28px -14px rgba(0, 0, 0, 0.65); /* modals only */
        /* Motion tokens — one easing + duration language (replaces ad-hoc values). */
        --ease: cubic-bezier(0.2, 0.6, 0.2, 1);
        --dur-fast: 120ms;
        --dur: 200ms;
        --ring: 0 0 0 1px var(--border);

        --font-sans: "Inter Variable", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        --font-display: "Sora Variable", "Sora", var(--font-sans);
        /* Mono for numerals + micro-labels — the "data instrument / quant terminal"
           signal (Bloomberg/Vercel-Geist/FT). Tabular + slashed-zero already set. */
        --font-mono: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
        --maxw: 1180px;
      }

      /* Stage colour ramp — a single cool→warm progression that ENCODES advancement
         toward the Final (gold), replacing the old arbitrary rainbow. Third place is
         deliberately neutral grey: a consolation, not an escalation. */
      :root {
        --stage-group: #5a87c4;  /* cool blue — earliest */
        --stage-r32:   #4f93c9;
        --stage-r16:   #3fb0c0;
        --stage-qf:    #43c79a;
        --stage-sf:    #8fce5a;
        --stage-final: #f0c23a;  /* warm gold — the destination */
        --stage-3rd:   #79829f;  /* neutral — off the escalation ramp */
      }

      /* Data-viz: one home/draw/away palette (was hard-coded differently in ProbBar
         vs MatchCard). Draw uses LIGHT ink for AA contrast on its slate fill. */
      :root {
        --viz-home: #4a9eff; --viz-home-ink: #04121f;
        --viz-draw: #6b7494; --viz-draw-ink: #eef1fb;
        --viz-away: #f0a93a; --viz-away-ink: #20160a;
      }

      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--fg);
        line-height: 1.55;
        font-size: 15px;
        background-color: var(--bg);
        /* One restrained green wash (was three radials incl. magenta+cyan) — the
           single biggest "less neon, more instrument" lever the design team flagged.
           Colour now reads as signal, not ambient decoration. */
        background-image:
          radial-gradient(1000px 480px at 15% -10%, rgba(47, 182, 114, 0.03), transparent 60%);
        min-height: 100vh;
      }
      /* `background-attachment: fixed` causes janky repaints / scroll lag on
         mobile (and is GPU-costly on touch). Gate it to wide, hover-capable
         (desktop-like) viewports only. */
      @media (min-width: 860px) and (hover: hover) {
        body { background-attachment: fixed; }
      }
      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2, h3 { font-family: var(--font-display); }

      /* ---- Header / nav ---- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        border-bottom: 1px solid var(--border-soft);
        background: rgba(10, 12, 20, 0.72);
        backdrop-filter: saturate(160%) blur(14px);
        -webkit-backdrop-filter: saturate(160%) blur(14px);
      }
      .site-header nav {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0.7rem 1.5rem;
        flex-wrap: nowrap;
        /* overflow stays VISIBLE here so the "More" dropdown isn't clipped; the
           horizontal scroll lives on the inner .nav-scroll instead. */
        overflow: visible;
      }
      /* The scrollable strip of primary links. Scrolls horizontally on overflow
         (mobile) without clipping the dropdown, which is a sibling outside it. */
      .nav-scroll {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        flex: 1 1 auto;
        min-width: 0;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none; /* Firefox: hide scrollbar */
      }
      .nav-scroll::-webkit-scrollbar { height: 0; width: 0; } /* hide WebKit scrollbar */
      .site-header nav .brand,
      .site-header nav .nav-more,
      .site-header nav a.navlink { flex: 0 0 auto; } /* don't shrink items into the scroll */
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.02rem;
        letter-spacing: -0.02em;
        color: var(--fg);
        text-decoration: none;
        margin-right: 1.1rem;
      }
      .brand:hover { text-decoration: none; }
      .brand .crest {
        width: 1.9rem; height: 1.9rem; border-radius: 5px;
        display: grid; place-items: center;
        background: linear-gradient(140deg, var(--accent), var(--accent-2));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.3); /* glow removed — glow ≠ sharp */
        color: #03210f;
        font-size: 1.05rem;
      }
      .brand .wm { color: var(--muted); font-weight: 600; }
      .brand .wm b { color: var(--fg); font-weight: 800; }
      .site-header .spacer { flex: 1; }
      .site-header nav a.navlink {
        text-decoration: none;
        color: var(--muted);
        padding: 0.45rem 0.85rem;
        border-radius: var(--radius-sm);
        font-size: 0.92rem;
        font-weight: 500;
        line-height: 1;
        transition: color 0.15s ease, background 0.15s ease;
      }
      .site-header nav a.navlink:hover { color: var(--fg); background: var(--elev); text-decoration: none; }
      /* Active pill = subtle accent tint, not a solid green fill (editorial, not
         sportsbook). Colour carries the state; no glow. */
      .site-header nav a.navlink[aria-current="page"] {
        color: var(--accent);
        background: var(--accent-soft);
        font-weight: 700;
        box-shadow: inset 0 0 0 1px var(--accent-line);
      }

      /* "More" overflow dropdown — keeps the top bar uncluttered (static <details>,
         no JS needed; the inline script below only adds close-on-outside-click). */
      .nav-more { position: relative; flex: 0 0 auto; }
      .nav-more > summary {
        list-style: none; cursor: pointer; user-select: none;
        display: inline-flex; align-items: center; gap: 0.3rem;
        /* inherit the .navlink look (summary also carries .navlink) */
      }
      .nav-more > summary::-webkit-details-marker { display: none; }
      .nav-more > summary::after {
        content: "▾"; font-size: 0.7em; opacity: 0.8; transition: transform 0.15s ease;
      }
      .nav-more[open] > summary::after { transform: rotate(180deg); }
      .nav-more[open] > summary { color: var(--fg); background: var(--elev); }
      .nav-more-menu {
        position: absolute; right: 0; top: calc(100% + 0.45rem);
        display: flex; flex-direction: column; gap: 0.1rem; min-width: 184px;
        padding: 0.4rem; z-index: 40;
        background: var(--surface-2); border: 1px solid var(--border);
        border-radius: var(--radius); box-shadow: var(--shadow-lg);
      }
      .nav-more-menu a.navlink { display: block; width: 100%; }
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      /* Global visually-hidden utility (was redeclared per-page). */
      .sr-only {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
      }
      /* Skip link: first focusable element, revealed on focus. */
      .skip-link {
        position: fixed; top: 0.6rem; left: 0.6rem; z-index: 100;
        transform: translateY(-150%);
        background: var(--accent); color: #03210f; font-weight: 700;
        padding: 0.55rem 0.9rem; border-radius: var(--radius-sm);
        text-decoration: none; box-shadow: var(--shadow-lg);
        transition: transform 0.15s ease;
      }
      .skip-link:focus-visible { transform: translateY(0); }

      main { max-width: var(--maxw); margin: 0 auto; padding: 1.9rem 1.5rem 4rem; }
      /* One restrained entrance — content settles up on load. Reduced-motion safe. */
      @media (prefers-reduced-motion: no-preference) {
        main { animation: page-rise 0.34s var(--ease) both; }
        @keyframes page-rise { from { opacity: 0; transform: translateY(7px); } }
      }
      h1 { margin-top: 0; font-size: 1.75rem; font-weight: 700; letter-spacing: -0.03em; }
      /* h2 bumped 1.25→1.4rem: at 1.25 it was only ~16% above body and the section
         hierarchy collapsed; ~25% delta is the threshold the eye registers as a step. */
      h2 { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.03em; }
      h3 { font-size: 1.0625rem; font-weight: 600; color: var(--fg); }
      .subtle { color: var(--muted); }
      .muted-2 { color: var(--muted-2); }
      .meta { color: var(--muted); font-size: 0.9rem; }
      /* Micro-label: mono + wide tracking = the engineered "ledger label" look. */
      .eyebrow {
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--accent);
      }
      code {
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 0.05rem 0.4rem;
        font-size: 0.85em;
        font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
      }

      /* ---- Section heading ---- */
      .section-head {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin: 0 0 1rem;
      }
      .section-head h2 { margin: 0; }
      .section-head .count {
        font-size: 0.8rem;
        color: var(--muted-2);
        font-weight: 600;
        font-family: var(--font-sans);
      }
      .section-head .rule { flex: 1; height: 1px; background: linear-gradient(90deg, var(--border), transparent); }

      /* Hero chips (globalised — was redeclared on 6 pages). Numbers in mono. */
      .hero-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
      .hero-chip {
        display: inline-flex; align-items: baseline; gap: 0.35rem;
        padding: 0.35rem 0.8rem; border-radius: var(--radius-sm);
        border: 1px solid var(--border-strong); background: rgba(10,12,20,0.4);
        font-size: 0.85rem; color: var(--muted);
      }
      .hero-chip b { font-family: var(--font-mono); font-weight: 600; color: var(--fg); font-size: 0.95rem; font-variant-numeric: tabular-nums slashed-zero; }
      .hero-chip.accent { border-color: var(--accent-line); background: var(--accent-soft); }
      .hero-chip.accent b { color: var(--accent); }
      .hero-chip.link { color: var(--link); font-weight: 600; text-decoration: none; }
      .hero-chip.link:hover { border-color: var(--link); text-decoration: none; }

      /* ---- Tables ---- */
      .table-wrap {
        width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch;
        border: 1px solid var(--border-soft);
        border-radius: var(--radius);
        background: var(--surface);
      }
      /* Ruled, denser tables — tighter rows + a hairline header rule = ledger feel. */
      table { border-collapse: collapse; width: 100%; font-size: 0.875rem; }
      th, td { text-align: left; padding: 0.5rem 0.8rem; border-bottom: 1px solid var(--border-soft); }
      /* Vertical column rules — the "ruled ledger / engineered" look (FT/FiveThirtyEight). */
      th:not(:last-child), td:not(:last-child) { border-right: 1px solid var(--border-soft); }
      thead th { background: var(--surface-2); border-bottom: 1px solid var(--border); }
      tbody tr:last-child td { border-bottom: none; }
      th { color: var(--muted-2); font-family: var(--font-mono); font-weight: 600; white-space: nowrap; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; }
      tbody tr { transition: background var(--dur-fast) var(--ease); }
      tbody tr:hover { background: var(--elev); }
      /* Numeric cells in mono — figures line up as a ruled column of data. */
      td.num, th.num { text-align: right; font-family: var(--font-mono); font-variant-numeric: tabular-nums slashed-zero; }

      /* Mobile: wide tables (class="table--cards" + data-label on each td) collapse
         from a side-scrolling grid into stacked label:value cards. CSS-only, no JS. */
      @media (max-width: 560px) {
        .table--cards thead { display: none; }
        .table--cards, .table--cards tbody, .table--cards tr, .table--cards td { display: block; width: auto; }
        .table--cards tr {
          border: 1px solid var(--border); border-radius: var(--radius-sm);
          padding: 0.55rem 0.75rem; margin-bottom: 0.55rem; background: var(--surface);
        }
        .table--cards td {
          display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
          padding: 0.22rem 0; border: none; border-right: none; text-align: right;
          white-space: normal;
        }
        .table--cards td::before {
          content: attr(data-label);
          font-family: var(--font-mono); font-size: 0.64rem; font-weight: 600;
          text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted-2);
          text-align: left; white-space: nowrap; flex: none;
        }
        .table--cards td:first-child {
          justify-content: flex-start; font-weight: 700; text-align: left;
          padding-bottom: 0.45rem; margin-bottom: 0.4rem; border-bottom: 1px solid var(--border-soft);
        }
        .table--cards td:first-child::before { display: none; }
        .table--cards .table-wrap, .table-wrap:has(.table--cards) { border: none; }
      }

      /* ---- Panels & grid ---- */
      .panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.15rem 1.3rem;
        /* Flat + bordered: depth from the 1px edge + a crisp inset catch-light, not blur. */
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
      }
      .grid { display: grid; gap: 1rem; }
      .grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
      .grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
      .grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
      .cards-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); }

      /* ---- Stat cards ---- */
      /* Left-rail accent instead of a top gradient stripe (more considered, less
         "dashboard template"). Colour is a data role; magenta is demoted to neutral. */
      .stat-card {
        display: flex; flex-direction: column; gap: 0.4rem;
        border-left: 3px solid var(--accent);
      }
      .stat-card.tone-cyan { border-left-color: var(--cyan); }
      .stat-card.tone-warn { border-left-color: var(--warn); }
      .stat-card.tone-mag  { border-left-color: var(--border-strong); }
      .stat-label { color: var(--muted); font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }
      .stat-value { font-family: var(--font-mono); font-size: 1.8rem; font-weight: 600; letter-spacing: -0.02em; font-variant-numeric: tabular-nums slashed-zero; line-height: 1.05; }
      .stat-sub { font-size: 0.82rem; color: var(--muted-2); }
      .pos { color: var(--accent); }
      .neg { color: var(--bad); }

      /* ---- Pills & badges ---- */
      .pill {
        display: inline-flex; align-items: center; gap: 0.3rem;
        padding: 0.18rem 0.6rem;
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-sm);
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--muted);
        white-space: nowrap;
        line-height: 1.4;
        background: var(--surface-2);
      }
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.16rem 0.55rem;
        border-radius: var(--radius-sm);
        font-size: 0.72rem;
        font-weight: 700;
        white-space: nowrap;
        line-height: 1.45;
      }
      .badge-edge { background: var(--accent-soft); color: var(--accent); border: 1px solid var(--accent-line); }
      .badge-warn { background: var(--warn-soft); color: var(--warn); border: 1px solid rgba(255,181,36,0.4); }
      .badge-analyzed { background: var(--surface-3); color: var(--muted); border: 1px solid var(--border-strong); }
      .pill.win { color: var(--accent); border-color: var(--accent-line); background: var(--accent-soft); }
      .pill.loss { color: var(--bad); border-color: rgba(255,84,112,0.5); background: var(--bad-soft); }
      .pill.open { color: var(--warn); border-color: rgba(255,181,36,0.5); background: var(--warn-soft); }
      .pill.live { color: var(--bad); border-color: rgba(255,84,112,0.5); background: var(--bad-soft); }
      .pill.finished { color: var(--accent); border-color: var(--accent-line); background: var(--accent-soft); }

      /* live dot */
      .pill.live::before {
        content: ""; width: 0.5rem; height: 0.5rem; border-radius: 999px;
        background: var(--bad); box-shadow: 0 0 0 0 rgba(255,84,112,0.6);
        animation: pulse 1.6s infinite;
      }
      @keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(255,84,112,0.6); }
        70% { box-shadow: 0 0 0 6px rgba(255,84,112,0); }
        100% { box-shadow: 0 0 0 0 rgba(255,84,112,0); }
      }

      /* Stage chips (color-coded) */
      .stage-chip {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.16rem 0.6rem 0.16rem 0.5rem;
        border-radius: 999px;
        font-size: 0.72rem; font-weight: 700;
        letter-spacing: 0.02em;
        border: 1px solid var(--border-strong);
        background: var(--surface-2);
        color: var(--fg);
        white-space: nowrap;
      }
      .stage-chip::before {
        content: ""; width: 0.5rem; height: 0.5rem; border-radius: 999px;
        background: var(--chip, var(--muted));
        box-shadow: 0 0 8px var(--chip, var(--muted));
      }
      .stage-GROUP { --chip: var(--stage-group); }
      .stage-R32 { --chip: var(--stage-r32); }
      .stage-R16 { --chip: var(--stage-r16); }
      .stage-QF { --chip: var(--stage-qf); }
      .stage-SF { --chip: var(--stage-sf); }
      .stage-3RD { --chip: var(--stage-3rd); }
      .stage-FINAL { --chip: var(--stage-final); }

      /* ---- Probability bar ---- */
      .probbar {
        display: flex;
        height: 1.75rem;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 1px solid var(--border);
        font-size: 0.74rem;
        font-weight: 700;
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.3);
      }
      .probbar > span {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        overflow: hidden;
        white-space: nowrap;
        transition: flex var(--dur) var(--ease);
      }
      .probbar .seg-home { background: var(--viz-home); color: var(--viz-home-ink); }
      .probbar .seg-draw { background: var(--viz-draw); color: var(--viz-draw-ink); }
      .probbar .seg-away { background: var(--viz-away); color: var(--viz-away-ink); }
      .probbar-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem 1.2rem;
        margin-top: 0.6rem;
        font-size: 0.82rem;
        color: var(--muted);
      }
      .probbar-legend b { color: var(--fg); font-weight: 700; }
      .probbar-legend .swatch { display: inline-block; width: 0.7rem; height: 0.7rem; border-radius: 3px; margin-right: 0.4rem; vertical-align: -1px; }

      .prose { line-height: 1.7; }
      .prose :first-child { margin-top: 0; }
      .prose a { color: var(--link); }
      .prose strong { color: var(--fg); }
      .prose ul { padding-left: 1.2rem; }
      .prose li { margin: 0.25rem 0; }

      hr { border: none; border-top: 1px solid var(--border-soft); margin: 1.4rem 0; }

      .site-footer {
        max-width: var(--maxw); margin: 0 auto;
        padding: 1.5rem; color: var(--muted-2); font-size: 0.82rem;
        border-top: 1px solid var(--border-soft);
      }
      .site-footer .rg { margin: 0 0 0.6rem; line-height: 1.55; max-width: 80ch; }
      .site-footer .rg b { color: var(--muted); }
      .site-footer .rg a { color: var(--link); }
      .site-footer .rg.disclose { color: var(--muted-2); font-size: 0.78rem; }
      .site-footer .rg-tag {
        display: inline-block; margin-right: 0.4rem;
        font-weight: 800; font-size: 0.7rem; color: var(--warn);
        border: 1px solid rgba(255,181,36,0.45); background: var(--warn-soft);
        border-radius: 6px; padding: 0.02rem 0.34rem; vertical-align: 1px;
      }
      .site-footer .foot-meta {
        margin: 0.9rem 0 0; padding-top: 0.9rem;
        border-top: 1px solid var(--border-soft);
        display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: center;
      }
      .site-footer .dotsep { color: var(--border-strong); }

      /* ---- Responsive ---- */
      @media (max-width: 860px) {
        .grid.cols-3 { grid-template-columns: 1fr; }
      }
      @media (max-width: 720px) {
        body { font-size: 14px; }
        main { padding: 1.3rem 1rem 3rem; }
        .site-header nav { padding: 0.6rem 1rem; gap: 0.15rem; }
        .brand .wm { display: none; }
        .grid.cols-4 { grid-template-columns: repeat(2, 1fr); }
        .grid.cols-2 { grid-template-columns: 1fr; }
        .cards-grid { grid-template-columns: 1fr; }
        .stat-value { font-size: 1.6rem; }
        h1 { font-size: 1.55rem; }
        /* Larger touch targets (~44px) for the scrollable nav + filter controls. */
        .site-header nav a.navlink {
          padding: 0.6rem 0.85rem;
          font-size: 0.95rem;
          min-height: 44px;
          display: inline-flex;
          align-items: center;
        }
        .chip {
          min-height: 44px;
          padding: 0.5rem 0.9rem;
        }
        .sort select {
          min-height: 44px;
          padding: 0.5rem 2rem 0.5rem 0.8rem;
        }
      }
      /* Clear the fixed mobile bottom tab bar so the footer isn't hidden behind it. */
      @media (max-width: 720px) {
        .site-footer { padding-bottom: calc(72px + env(safe-area-inset-bottom)); }
      }
      @media (prefers-reduced-motion: reduce) {
        * { animation: none !important; transition: none !important; scroll-behavior: auto !important; }
      }
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
