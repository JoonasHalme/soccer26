        </a>
        <div class="nav-scroll">
          <a href="/" class="navlink" aria-current={isActive("/") ? "page" : undefined}>Dashboard</a>
          <a href="/edges" class="navlink" aria-current={isActive("/edges") ? "page" : undefined}>Edges</a>
          <a href="/matches" class="navlink" aria-current={isActive("/matches") ? "page" : undefined}>Matches</a>
          <a href="/groups" class="navlink" aria-current={isActive("/groups") ? "page" : undefined}>Groups</a>
          <a href="/bracket" class="navlink" aria-current={isActive("/bracket") ? "page" : undefined}>Bracket</a>
          <a href="/outrights" class="navlink" aria-current={isActive("/outrights") ? "page" : undefined}>Outrights</a>
          <a href="/bets" class="navlink" aria-current={isActive("/bets") ? "page" : undefined}>Bets</a>
          <a href="/calibration" class="navlink" aria-current={isActive("/calibration") ? "page" : undefined}>Calibration</a>
        </div>
        <details class="nav-more">
          <summary class="navlink" aria-current={moreActive ? "page" : undefined}>More</summary>
          <div class="nav-more-menu">
            <a href="/methodology" class="navlink" aria-current={isActive("/methodology") ? "page" : undefined}>Methodology</a>
            <a href="/divergence" class="navlink" aria-current={isActive("/divergence") ? "page" : undefined}>Divergence</a>
            <a href="/predict" class="navlink" aria-current={isActive("/predict") ? "page" : undefined}>Predict</a>
          </div>
        </details>
      </nav>
    </header>
    <script is:inline>
      // Scroll the active nav pill into view (the hidden-scrollbar nav otherwise
      // clips the current page's pill off the right edge on later routes). Adjusts
      // only the nav's own horizontal scroll, never the page.
      (function () {
        var nav = document.querySelector(".site-header .nav-scroll");
        var active = nav && nav.querySelector('a.navlink[aria-current="page"]');
        if (nav && active) {
          nav.scrollLeft = active.offsetLeft - nav.clientWidth / 2 + active.clientWidth / 2;
        }
        // Close the "More" dropdown when clicking outside it or pressing Escape.
        var more = document.querySelector(".nav-more");
        if (more) {
          document.addEventListener("click", function (e) {
            if (more.open && !more.contains(e.target)) more.open = false;
          });
          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") more.open = false;
          });
        }

        // Localize every <time data-lt> (rendered server-side in UTC) to the
        // viewer's own timezone. Matchday GROUPING stays Eastern (host region);
        // only the displayed start times follow the visitor. Must wait for the DOM
        // — this inline script runs before <main> (where the times live) is parsed.
        var FMT = {
          time: { hour: "2-digit", minute: "2-digit", hour12: false },
          date: { day: "numeric", month: "short" },
          datetime: { weekday: "short", day: "numeric", month: "short", hour: "2-digit", minute: "2-digit", hour12: false },
        };
        function localizeTimes() {
          document.querySelectorAll("time[data-lt]").forEach(function (el) {
            var d = new Date(el.getAttribute("data-lt"));
            if (isNaN(d.getTime())) return;
            var fmt = el.getAttribute("data-lt-fmt") || "datetime";
            var o = Object.assign({}, FMT[fmt] || FMT.datetime);
            if (fmt !== "date") o.timeZoneName = "short"; // append local tz, e.g. EDT/CET
            try {
              el.textContent = d.toLocaleString(undefined, o);
              el.title = d.toLocaleString(undefined, { weekday: "long", year: "numeric", month: "long", day: "numeric", hour: "2-digit", minute: "2-digit", timeZoneName: "short" });
            } catch (e) {}
          });
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", localizeTimes);
        } else {
          localizeTimes();
        }
      })();
    </script>
    <main id="main">
      <slot />
    </main>
