---
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import MobileNav from "../components/MobileNav.astro";
interface Props {
  title?: string;
  description?: string;
  /** Build-time OG card path (see src/pages/og/). Defaults to the site card. */
  ogImage?: string;
}
const {
  title = "Soccer 26",
  description = "A transparent, calibration-first World Cup 2026 forecasting model: win probabilities, value edges vs the de-vigged market, and calls graded against results in public. Analysis, not tips.",
  ogImage = "/og/default.png",
} = Astro.props;
const path = Astro.url.pathname;
// Absolute once a deploy domain is set as `site` in astro.config (SITE_URL); until
// then these resolve relative to the current origin. OG/canonical need a public
// absolute URL to work on social + for SEO — all upgrade automatically with `site`.
const ogImageUrl = Astro.site ? new URL(ogImage, Astro.site).href : ogImage;
const canonicalUrl = Astro.site ? new URL(path, Astro.site).href : path;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
// Secondary routes live under a "More" dropdown so the top bar stays uncluttered.
const MORE_ROUTES = ["/edges", "/calibration", "/divergence", "/predict", "/methodology"];
const moreActive = MORE_ROUTES.some((h) => isActive(h));
const year = new Date().getFullYear();
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0c12" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="alternate" type="application/rss+xml" title="Soccer 26 — value edges & team news" href="/feed.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      :root {
        /* Base surfaces — deep ink-navy night (cooler/neutral-er than before so the
           azure accent has maximum hue-separation from its own background). */
        --bg: #0a0c12;
        --bg-2: #0d1018;
        --surface: #12161f;
        --surface-2: #171c28;
        --surface-3: #1d2433;
        --elev: rgba(255, 255, 255, 0.04);
        /* Crisper, higher-contrast hairlines (was muddy low-contrast blue-grey) for
           the "engineered / ruled" feel of a sharp data UI. */
        --border: #2a3142;
        --border-soft: #1f2533;
        --border-strong: #3a4357;

        /* Text */
        /* Softer off-white (was near-pure #eef1fb, which glared on the dark canvas).
           Still ~12:1 on --bg, so contrast stays well above AA. */
        --fg: #ced5e2;
        --muted: #909aae;
        --muted-2: #69728a;

        /* PRIMARY — steel-azure. The one brand colour; encodes positive/edge/win.
           Desaturated (not neon) so it reads "instrument", not "casino". Green is
           retired entirely — one confident cool identity instead of green+indigo. */
        --accent: #3e7bd6;
        --accent-2: #2f63b4;
        --accent-soft: rgba(62, 123, 214, 0.13);
        --accent-line: rgba(62, 123, 214, 0.42);
        --accent-ink: #03101f;            /* text/icons on azure fills */

        /* SECONDARY — one cooler teal for "model/info" callouts, clearly separated
           in hue from the brand azure so the two never read as the same colour. */
        --info: #4fb6c4;
        --info-soft: rgba(79, 182, 196, 0.13);
        --info-line: rgba(79, 182, 196, 0.40);
        --info-ink: #03161a;

        /* Semantic — restrained (pulled back from neon to read calm). */
        --warn: #e0a32e;
        --warn-soft: rgba(224, 163, 46, 0.13);
        --warn-line: rgba(224, 163, 46, 0.40);
        --bad: #e8617c;
        --bad-soft: rgba(232, 97, 124, 0.13);
        --bad-line: rgba(232, 97, 124, 0.42);
        --bad-ink: #1a0507;
        --good: var(--accent);
        --link: var(--info);

        /* Back-compat aliases — old decorative hues now resolve to the disciplined
           palette so existing var(--cyan)/var(--magenta) refs keep working until the
           per-component cleanup pass renames them. */
        --cyan: var(--info);
        --cyan-soft: var(--info-soft);
        --magenta: var(--border-strong);
        --magenta-soft: var(--accent-soft);

        /* Sharp by request — crisp, engineered corners, not soft app rounding.
           Data containers ~6px, small elements 4px, hero 8px; status dots stay round. */
        --radius: 6px;
        --radius-sm: 4px;
        --radius-lg: 8px;
        /* Flatter, tighter elevation — depth via border + surface, not heavy blur
           (design-team direction: "calm authority, an instrument not an app"). */
        --shadow: 0 1px 0 rgba(0, 0, 0, 0.5);            /* hairline contact, not a glow */
        --shadow-md: 0 4px 12px -6px rgba(0, 0, 0, 0.6); /* floating layers only */
        --shadow-lg: 0 12px 28px -14px rgba(0, 0, 0, 0.65); /* modals only */
        /* Motion tokens — one easing + duration language (replaces ad-hoc values). */
        --ease: cubic-bezier(0.2, 0.6, 0.2, 1);
        --dur-fast: 120ms;
        --dur: 200ms;
        --ring: 0 0 0 1px var(--border);

        --font-sans: "Inter Variable", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        /* Monolithic Inter (the "Instrument" direction): headings are Inter at a
           heavier weight + tight tracking — Sora was dropped because a geometric
           display face read as "template". Mono = every figure + micro-label. */
        --font-display: var(--font-sans);
        --font-mono: "JetBrains Mono Variable", "JetBrains Mono", ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;

        /* Modular type scale (~1.2 ratio + one display leap) + line-heights + weights.
           Everything points here instead of hand-picking sizes per component. */
        --t-display: 2.5rem; --t-h1: 1.875rem; --t-h2: 1.375rem; --t-h3: 1.125rem;
        --t-lg: 1rem; --t-body: 0.9375rem; --t-sm: 0.8125rem; --t-micro: 0.6875rem;
        --t-stat: 1.75rem;          /* the single "big number" size */
        --lh-tight: 1.15; --lh-snug: 1.3; --lh-ui: 1.5; --lh-prose: 1.7;
        --w-reg: 400; --w-med: 500; --w-semi: 600; --w-bold: 700;

        /* Spacing — strict 4 / 8 grid (replaces the off-grid 0.85/0.95/1.15rem zoo). */
        --s-1: 0.25rem; --s-2: 0.5rem; --s-3: 0.75rem; --s-4: 1rem;
        --s-5: 1.5rem; --s-6: 2rem; --s-7: 3rem; --s-8: 4rem;

        --maxw: 1180px;
        --measure: 68ch;            /* prose max-width — one value */
      }

      /* Stage colour ramp — a single cool→warm progression that ENCODES advancement
         toward the Final (gold), replacing the old arbitrary rainbow. Third place is
         deliberately neutral grey: a consolation, not an escalation. */
      :root {
        --stage-group: #3e7bd6;  /* = brand azure — earliest */
        --stage-r32:   #3f8fcf;
        --stage-r16:   #44a6c2;
        --stage-qf:    #6fb59e;
        --stage-sf:    #b8bd5f;   /* olive-gold transition */
        --stage-final: #e8b833;  /* one gold — the destination */
        --stage-3rd:   #79829f;  /* neutral — off the escalation ramp */
      }

      /* Data-viz: one home/draw/away palette (was hard-coded differently in ProbBar
         vs MatchCard). Draw uses LIGHT ink for AA contrast on its slate fill. */
      :root {
        --viz-home: #3e7bd6; --viz-home-ink: #03101f;  /* = brand azure */
        --viz-draw: #6b7490; --viz-draw-ink: #eef1fb;
        --viz-away: #e8b833; --viz-away-ink: #20160a;  /* = --stage-final gold */
      }

      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--fg);
        line-height: var(--lh-ui);
        font-size: var(--t-body);
        /* Flat near-black instrument canvas — no ambient wash/glow (the "Instrument"
           direction: depth comes from surfaces + 1px borders, never gradients). */
        background-color: var(--bg);
        min-height: 100vh;
      }
      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2, h3 { font-family: var(--font-display); }

      /* ---- Header / nav ---- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        border-bottom: 1px solid var(--border-soft);
        background: rgba(10, 12, 20, 0.72);
        backdrop-filter: saturate(160%) blur(14px);
        -webkit-backdrop-filter: saturate(160%) blur(14px);
      }
      .site-header nav {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0.7rem 1.5rem;
        flex-wrap: nowrap;
        /* overflow stays VISIBLE here so the "More" dropdown isn't clipped; the
           horizontal scroll lives on the inner .nav-scroll instead. */
        overflow: visible;
      }
      /* The scrollable strip of primary links. Scrolls horizontally on overflow
         (mobile) without clipping the dropdown, which is a sibling outside it. */
      .nav-scroll {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        flex: 1 1 auto;
        min-width: 0;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none; /* Firefox: hide scrollbar */
      }
      .nav-scroll::-webkit-scrollbar { height: 0; width: 0; } /* hide WebKit scrollbar */
      .site-header nav .brand,
      .site-header nav .nav-more,
      .site-header nav a.navlink { flex: 0 0 auto; } /* don't shrink items into the scroll */
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.02rem;
        letter-spacing: -0.02em;
        color: var(--fg);
        text-decoration: none;
        margin-right: 1.1rem;
      }
      .brand:hover { text-decoration: none; }
      .brand .crest {
        width: 1.9rem; height: 1.9rem; border-radius: 5px;
        display: grid; place-items: center;
        background: linear-gradient(140deg, var(--accent), var(--accent-2));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.3); /* glow removed — glow ≠ sharp */
        color: var(--accent-ink);
        font-size: 1.05rem;
      }
      .brand .wm { color: var(--muted); font-weight: 600; }
      .brand .wm b { color: var(--fg); font-weight: 800; }
      .site-header .spacer { flex: 1; }
      .site-header nav a.navlink {
        text-decoration: none;
        color: var(--muted);
        padding: 0.45rem 0.85rem;
        border-radius: var(--radius-sm);
        font-size: 0.92rem;
        font-weight: 500;
        line-height: 1;
        transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
      }
      .site-header nav a.navlink:hover { color: var(--fg); background: var(--elev); text-decoration: none; }
      /* Active pill = subtle accent tint, not a solid green fill (editorial, not
         sportsbook). Colour carries the state; no glow. */
      .site-header nav a.navlink[aria-current="page"] {
        color: var(--accent);
        background: var(--accent-soft);
        font-weight: 700;
        box-shadow: inset 0 0 0 1px var(--accent-line);
      }

      /* "More" overflow dropdown — keeps the top bar uncluttered (static <details>,
         no JS needed; the inline script below only adds close-on-outside-click). */
      .nav-more { position: relative; flex: 0 0 auto; }
      .nav-more > summary {
        list-style: none; cursor: pointer; user-select: none;
        display: inline-flex; align-items: center; gap: 0.3rem;
        /* inherit the .navlink look (summary also carries .navlink) */
      }
      .nav-more > summary::-webkit-details-marker { display: none; }
      .nav-more > summary::after {
        content: "▾"; font-size: 0.7em; opacity: 0.8; transition: transform var(--dur-fast) var(--ease);
      }
      .nav-more[open] > summary::after { transform: rotate(180deg); }
      .nav-more[open] > summary { color: var(--fg); background: var(--elev); }
      .nav-more-menu {
        position: absolute; right: 0; top: calc(100% + 0.45rem);
        display: flex; flex-direction: column; gap: 0.1rem; min-width: 184px;
        padding: 0.4rem; z-index: 40;
        background: var(--surface-2); border: 1px solid var(--border);
        border-radius: var(--radius); box-shadow: var(--shadow-lg);
      }
      .nav-more-menu a.navlink { display: block; width: 100%; }
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      /* Global visually-hidden utility (was redeclared per-page). */
      .sr-only {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
      }
      /* Skip link: first focusable element, revealed on focus. */
      .skip-link {
        position: fixed; top: 0.6rem; left: 0.6rem; z-index: 100;
        transform: translateY(-150%);
        background: var(--accent); color: var(--accent-ink); font-weight: 700;
        padding: 0.55rem 0.9rem; border-radius: var(--radius-sm);
        text-decoration: none; box-shadow: var(--shadow-lg);
        transition: transform var(--dur-fast) var(--ease);
      }
      .skip-link:focus-visible { transform: translateY(0); }

      main { max-width: var(--maxw); margin: 0 auto; padding: 1.9rem 1.5rem 4rem; }
      /* A quiet opacity-only settle on load (motion belongs on interaction, not
         arrival — the translateY rise was a "templated entrance" tell). */
      @media (prefers-reduced-motion: no-preference) {
        main { animation: page-fade 0.24s var(--ease) both; }
        @keyframes page-fade { from { opacity: 0; } }
      }
      /* Headings on the modular scale; Inter at heavier weight + tight tracking
         carries the "display" role now that Sora is gone. */
      h1 { margin-top: 0; font-size: var(--t-h1); line-height: var(--lh-tight); font-weight: var(--w-bold); letter-spacing: -0.025em; }
      h2 { font-size: var(--t-h2); line-height: var(--lh-tight); font-weight: var(--w-bold); letter-spacing: -0.02em; }
      h3 { font-size: var(--t-h3); line-height: var(--lh-snug); font-weight: 650; letter-spacing: -0.01em; color: var(--fg); }
      .subtle { color: var(--muted); }
      .muted-2 { color: var(--muted-2); }
      .meta { color: var(--muted); font-size: 0.9rem; }
      /* Micro-label: mono + wide tracking = the engineered "ledger label" look. */
      .eyebrow {
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: var(--t-micro);
        font-weight: 600;
        color: var(--accent);
      }
      code {
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 0.05rem 0.4rem;
        font-size: 0.85em;
        font-family: ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
      }

      /* ---- Section heading ---- */
      .section-head {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin: 0 0 1rem;
      }
      .section-head h2 { margin: 0; }
      .section-head .count {
        font-size: 0.8rem;
        color: var(--muted-2);
        font-weight: 600;
        font-family: var(--font-sans);
      }
      .section-head .rule { flex: 1; height: 1px; background: linear-gradient(90deg, var(--border), transparent); }

      /* Hero chips (globalised — was redeclared on 6 pages). Numbers in mono. */
      .hero-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
      .hero-chip {
        display: inline-flex; align-items: baseline; gap: 0.35rem;
        padding: 0.35rem 0.8rem; border-radius: var(--radius-sm);
        border: 1px solid var(--border-strong); background: rgba(10,12,20,0.4);
        font-size: 0.85rem; color: var(--muted);
      }
      .hero-chip b { font-family: var(--font-mono); font-weight: 600; color: var(--fg); font-size: 0.95rem; font-variant-numeric: tabular-nums slashed-zero; }
      .hero-chip.accent { border-color: var(--accent-line); background: var(--accent-soft); }
      .hero-chip.accent b { color: var(--accent); }
      .hero-chip.link { color: var(--link); font-weight: 600; text-decoration: none; }
      .hero-chip.link:hover { border-color: var(--link); text-decoration: none; }

      /* ---- Tables ---- */
      .table-wrap {
        width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch;
        border: 1px solid var(--border-soft);
        border-radius: var(--radius);
        background: var(--surface);
      }
      /* Ruled, denser tables — tighter rows + a hairline header rule = ledger feel. */
      table { border-collapse: collapse; width: 100%; font-size: 0.875rem; }
      th, td { text-align: left; padding: 0.5rem 0.8rem; border-bottom: 1px solid var(--border-soft); }
      /* Horizontal hairlines only (FT/FBref/538 ledger). Right-alignment + whitespace
         separate columns — full gridlines read as a spreadsheet export. */
      thead th { background: var(--surface-2); border-bottom: 1px solid var(--border); }
      tbody tr:last-child td { border-bottom: none; }
      th { color: var(--muted-2); font-family: var(--font-mono); font-weight: 600; white-space: nowrap; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; }
      tbody tr { transition: background var(--dur-fast) var(--ease); }
      tbody tr:hover { background: var(--elev); }
      /* Numeric cells in mono — figures line up as a ruled column of data. */
      td.num, th.num { text-align: right; font-family: var(--font-mono); font-variant-numeric: tabular-nums slashed-zero; }

      /* Mobile: wide tables (class="table--cards" + data-label on each td) collapse
         from a side-scrolling grid into stacked label:value cards. CSS-only, no JS. */
      @media (max-width: 560px) {
        .table--cards thead { display: none; }
        .table--cards, .table--cards tbody, .table--cards tr, .table--cards td { display: block; width: auto; }
        .table--cards tr {
          border: 1px solid var(--border); border-radius: var(--radius-sm);
          padding: 0.55rem 0.75rem; margin-bottom: 0.55rem; background: var(--surface);
        }
        .table--cards td {
          display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;
          padding: 0.22rem 0; border: none; border-right: none; text-align: right;
          white-space: normal;
        }
        .table--cards td::before {
          content: attr(data-label);
          font-family: var(--font-mono); font-size: 0.64rem; font-weight: 600;
          text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted-2);
          text-align: left; white-space: nowrap; flex: none;
        }
        .table--cards td:first-child {
          justify-content: flex-start; font-weight: 700; text-align: left;
          padding-bottom: 0.45rem; margin-bottom: 0.4rem; border-bottom: 1px solid var(--border-soft);
        }
        .table--cards td:first-child::before { display: none; }
        .table--cards .table-wrap, .table-wrap:has(.table--cards) { border: none; }
      }

      /* ---- Panels & grid ---- */
      .panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.15rem 1.3rem;
        /* Flat + bordered: depth from the 1px edge + a crisp inset catch-light, not blur. */
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
      }
      .grid { display: grid; gap: 1rem; }
      .grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
      .grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
      .grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
      .cards-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); }

      /* ---- Stat cards ---- */
      /* Left-rail accent instead of a top gradient stripe (more considered, less
         "dashboard template"). Colour is a data role; magenta is demoted to neutral. */
      .stat-card {
        display: flex; flex-direction: column; gap: 0.4rem;
        border-left: 3px solid var(--accent);
      }
      .stat-card.tone-cyan { border-left-color: var(--cyan); }
      .stat-card.tone-warn { border-left-color: var(--warn); }
      .stat-card.tone-mag  { border-left-color: var(--border-strong); }
      .stat-label { color: var(--muted); font-family: var(--font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }
      .stat-value { font-family: var(--font-mono); font-size: var(--t-stat); font-weight: 600; letter-spacing: -0.02em; font-variant-numeric: tabular-nums slashed-zero; line-height: 1.05; }
      .stat-sub { font-size: 0.82rem; color: var(--muted-2); }
      .pos { color: var(--accent); }
      .neg { color: var(--bad); }

      /* ---- Pills & badges ---- */
      .pill {
        display: inline-flex; align-items: center; gap: 0.3rem;
        padding: 0.18rem 0.6rem;
        border: 1px solid var(--border-strong);
        border-radius: var(--radius-sm);
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--muted);
        white-space: nowrap;
        line-height: 1.4;
        background: var(--surface-2);
      }
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.16rem 0.55rem;
        border-radius: var(--radius-sm);
        font-size: 0.72rem;
        font-weight: 700;
        white-space: nowrap;
        line-height: 1.45;
      }
      .badge-edge { background: var(--accent-soft); color: var(--accent); border: 1px solid var(--accent-line); }
      .badge-warn { background: var(--warn-soft); color: var(--warn); border: 1px solid var(--warn-line); }
      .badge-analyzed { background: var(--surface-3); color: var(--muted); border: 1px solid var(--border-strong); }
      .pill.win { color: var(--accent); border-color: var(--accent-line); background: var(--accent-soft); }
      .pill.loss { color: var(--bad); border-color: var(--bad-line); background: var(--bad-soft); }
      .pill.open { color: var(--warn); border-color: var(--warn-line); background: var(--warn-soft); }
      .pill.live { color: var(--bad); border-color: var(--bad-line); background: var(--bad-soft); }
      .pill.finished { color: var(--accent); border-color: var(--accent-line); background: var(--accent-soft); }

      /* live dot — a quiet opacity breathe, no expanding glow ring (no halo). */
      .pill.live::before {
        content: ""; width: 0.5rem; height: 0.5rem; border-radius: 999px;
        background: var(--bad);
        animation: live-breathe 1.8s ease-in-out infinite;
      }
      @keyframes live-breathe { 50% { opacity: 0.45; } }

      /* Stage chips (color-coded) */
      .stage-chip {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.16rem 0.6rem 0.16rem 0.5rem;
        border-radius: 999px;
        font-size: 0.72rem; font-weight: 700;
        letter-spacing: 0.02em;
        border: 1px solid var(--border-strong);
        background: var(--surface-2);
        color: var(--fg);
        white-space: nowrap;
      }
      .stage-chip::before {
        content: ""; width: 0.5rem; height: 0.5rem; border-radius: 999px;
        background: var(--chip, var(--muted));   /* solid dot, no glow halo */
      }
      .stage-GROUP { --chip: var(--stage-group); }
      .stage-R32 { --chip: var(--stage-r32); }
      .stage-R16 { --chip: var(--stage-r16); }
      .stage-QF { --chip: var(--stage-qf); }
      .stage-SF { --chip: var(--stage-sf); }
      .stage-3RD { --chip: var(--stage-3rd); }
      .stage-FINAL { --chip: var(--stage-final); }

      /* Filter chip (toggle button) — globalised; was copy-pasted on 3 pages. */
      .chip {
        font: inherit; cursor: pointer;
        display: inline-flex; align-items: center; gap: 0.3rem;
        min-height: 44px;
        padding: 0.3rem 0.85rem; border-radius: var(--radius-sm);
        border: 1px solid var(--border-strong);
        background: var(--surface-2); color: var(--muted);
        font-size: 0.8rem; font-weight: 600;
        transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
      }
      .chip:hover { color: var(--fg); }
      .chip:active { transform: translateY(1px); }
      .chip.is-on {
        color: var(--accent-ink); border-color: transparent;
        background: linear-gradient(140deg, var(--accent), var(--accent-2));
      }

      /* Button primitive — one clickable language with real states (was several
         bespoke buttons). Tactile :active press is what reads as "expensive". */
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem;
        height: 38px; padding: 0 1rem; border-radius: var(--radius-sm);
        font: inherit; font-size: 0.9rem; font-weight: 600; line-height: 1;
        cursor: pointer; white-space: nowrap; text-decoration: none;
        border: 1px solid transparent;
        transition: background var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease),
                    color var(--dur-fast) var(--ease), filter var(--dur-fast) var(--ease);
      }
      .btn:hover { text-decoration: none; }
      .btn:active { transform: translateY(1px); }
      .btn:disabled, .btn[aria-disabled="true"] { opacity: 0.55; cursor: not-allowed; }
      .btn--primary { background: linear-gradient(140deg, var(--accent), var(--accent-2)); color: var(--accent-ink); }
      .btn--primary:hover { filter: brightness(1.06); }
      .btn--ghost { background: var(--surface-2); border-color: var(--border-strong); color: var(--fg); }
      .btn--ghost:hover { border-color: var(--accent-line); }

      /* ---- Probability bar ---- */
      .probbar {
        display: flex;
        height: 1.75rem;
        border-radius: var(--radius-sm);
        overflow: hidden;
        border: 1px solid var(--border);
        font-size: 0.74rem;
        font-weight: 700;
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.3);
      }
      .probbar > span {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        overflow: hidden;
        white-space: nowrap;
        transition: flex var(--dur) var(--ease);
      }
      .probbar .seg-home { background: var(--viz-home); color: var(--viz-home-ink); }
      .probbar .seg-draw { background: var(--viz-draw); color: var(--viz-draw-ink); }
      .probbar .seg-away { background: var(--viz-away); color: var(--viz-away-ink); }
      .probbar-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem 1.2rem;
        margin-top: 0.6rem;
        font-size: 0.82rem;
        color: var(--muted);
      }
      .probbar-legend b { color: var(--fg); font-weight: 700; }
      .probbar-legend .swatch { display: inline-block; width: 0.7rem; height: 0.7rem; border-radius: 3px; margin-right: 0.4rem; vertical-align: -1px; }

      .prose { line-height: 1.7; }
      .prose :first-child { margin-top: 0; }
      .prose a { color: var(--link); }
      .prose strong { color: var(--fg); }
      .prose ul { padding-left: 1.2rem; }
      .prose li { margin: 0.25rem 0; }

      hr { border: none; border-top: 1px solid var(--border-soft); margin: 1.4rem 0; }

      .site-footer {
        max-width: var(--maxw); margin: 0 auto;
        padding: 1.5rem; color: var(--muted-2); font-size: 0.82rem;
        border-top: 1px solid var(--border-soft);
      }
      .site-footer .rg { margin: 0 0 0.6rem; line-height: 1.55; max-width: 80ch; }
      .site-footer .rg b { color: var(--muted); }
      .site-footer .rg a { color: var(--link); }
      .site-footer .rg.disclose { color: var(--muted-2); font-size: 0.78rem; }
      .site-footer .rg-tag {
        display: inline-block; margin-right: 0.4rem;
        font-weight: 800; font-size: 0.7rem; color: var(--warn);
        border: 1px solid var(--warn-line); background: var(--warn-soft);
        border-radius: 6px; padding: 0.02rem 0.34rem; vertical-align: 1px;
      }
      .site-footer .foot-meta {
        margin: 0.9rem 0 0; padding-top: 0.9rem;
        border-top: 1px solid var(--border-soft);
        display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: center;
      }
      .site-footer .dotsep { color: var(--border-strong); }

      /* ---- Responsive ---- */
      @media (max-width: 860px) {
        .grid.cols-3 { grid-template-columns: 1fr; }
      }
      @media (max-width: 720px) {
        body { font-size: 14px; }
        main { padding: 1.3rem 1rem 3rem; }
        .site-header nav { padding: 0.6rem 1rem; gap: 0.15rem; }
        .brand .wm { display: none; }
        .grid.cols-4 { grid-template-columns: repeat(2, 1fr); }
        .grid.cols-2 { grid-template-columns: 1fr; }
        .cards-grid { grid-template-columns: 1fr; }
        .stat-value { font-size: 1.6rem; }
        h1 { font-size: 1.55rem; }
        /* Larger touch targets (~44px) for the scrollable nav + filter controls. */
        .site-header nav a.navlink {
          padding: 0.6rem 0.85rem;
          font-size: 0.95rem;
          min-height: 44px;
          display: inline-flex;
          align-items: center;
        }
        .chip {
          min-height: 44px;
          padding: 0.5rem 0.9rem;
        }
        .sort select {
          min-height: 44px;
          padding: 0.5rem 2rem 0.5rem 0.8rem;
        }
      }
      /* Clear the fixed mobile bottom tab bar so the footer isn't hidden behind it. */
      @media (max-width: 720px) {
        .site-footer { padding-bottom: calc(72px + env(safe-area-inset-bottom)); }
      }
      @media (prefers-reduced-motion: reduce) {
        * { animation: none !important; transition: none !important; scroll-behavior: auto !important; }
      }
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site-header">
      <nav aria-label="Primary">
        <a href="/" class="brand">
          <span class="crest" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round" stroke-linecap="round">
              <circle cx="12" cy="12" r="8.5" />
              <path d="M12 7.1l4.4 3.2-1.7 5.2H9.3L7.6 10.3z" />
            </svg>
          </span>
          <span class="wm"><b>SOCCER</b> 26</span>
        </a>
        <div class="nav-scroll">
          <a href="/" class="navlink" aria-current={isActive("/") ? "page" : undefined}>Dashboard</a>
          <a href="/road-to-the-world-cup" class="navlink" aria-current={isActive("/road-to-the-world-cup") ? "page" : undefined}>Road to WC</a>
          <a href="/matches" class="navlink" aria-current={isActive("/matches") ? "page" : undefined}>Matches</a>
          <a href="/groups" class="navlink" aria-current={isActive("/groups") ? "page" : undefined}>Groups</a>
          <a href="/bracket" class="navlink" aria-current={isActive("/bracket") ? "page" : undefined}>Bracket</a>
          <a href="/outrights" class="navlink" aria-current={isActive("/outrights") ? "page" : undefined}>Outrights</a>
        </div>
        <details class="nav-more">
          <summary class="navlink" aria-current={moreActive ? "page" : undefined}>More</summary>
          <div class="nav-more-menu">
            <a href="/edges" class="navlink" aria-current={isActive("/edges") ? "page" : undefined}>Edges</a>
            <a href="/calibration" class="navlink" aria-current={isActive("/calibration") ? "page" : undefined}>Calibration</a>
            <a href="/methodology" class="navlink" aria-current={isActive("/methodology") ? "page" : undefined}>Methodology</a>
            <a href="/divergence" class="navlink" aria-current={isActive("/divergence") ? "page" : undefined}>Divergence</a>
            <a href="/predict" class="navlink" aria-current={isActive("/predict") ? "page" : undefined}>Predict</a>
          </div>
        </details>
      </nav>
    </header>
    <script is:inline>
      // Scroll the active nav pill into view (the hidden-scrollbar nav otherwise
      // clips the current page's pill off the right edge on later routes). Adjusts
      // only the nav's own horizontal scroll, never the page.
      (function () {
        var nav = document.querySelector(".site-header .nav-scroll");
        var active = nav && nav.querySelector('a.navlink[aria-current="page"]');
        if (nav && active) {
          nav.scrollLeft = active.offsetLeft - nav.clientWidth / 2 + active.clientWidth / 2;
        }
        // Close the "More" dropdown when clicking outside it or pressing Escape.
        var more = document.querySelector(".nav-more");
        if (more) {
          document.addEventListener("click", function (e) {
            if (more.open && !more.contains(e.target)) more.open = false;
          });
          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") more.open = false;
          });
        }

        // Localize every <time data-lt> (rendered server-side in UTC) to the
        // viewer's own timezone. Matchday GROUPING stays Eastern (host region);
        // only the displayed start times follow the visitor. Must wait for the DOM
        // — this inline script runs before <main> (where the times live) is parsed.
        var FMT = {
          time: { hour: "2-digit", minute: "2-digit", hour12: false },
          date: { day: "numeric", month: "short" },
          datetime: { weekday: "short", day: "numeric", month: "short", hour: "2-digit", minute: "2-digit", hour12: false },
        };
        function localizeTimes() {
          document.querySelectorAll("time[data-lt]").forEach(function (el) {
            var d = new Date(el.getAttribute("data-lt"));
            if (isNaN(d.getTime())) return;
            var fmt = el.getAttribute("data-lt-fmt") || "datetime";
            var o = Object.assign({}, FMT[fmt] || FMT.datetime);
            if (fmt !== "date") o.timeZoneName = "short"; // append local tz, e.g. EDT/CET
            try {
              el.textContent = d.toLocaleString(undefined, o);
              el.title = d.toLocaleString(undefined, { weekday: "long", year: "numeric", month: "long", day: "numeric", hour: "2-digit", minute: "2-digit", timeZoneName: "short" });
            } catch (e) {}
          });
        }
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", localizeTimes);
        } else {
          localizeTimes();
        }
      })();
    </script>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p class="rg">
        <span class="rg-tag">18+</span>
        For informational and entertainment purposes only — <b>not betting or financial
        advice</b>. Gambling involves risk; never stake more than you can afford to lose,
        and check that betting is legal in your jurisdiction. If gambling is affecting you,
